@page "/my-tickets"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject NavigationManager NavigationManager

<div class="my-tickets-page">
    @if (!BookingService.DaDangNhap || BookingService.HanhKhachHienTai == null)
    {
        <!-- Not Logged In -->
        <div class="not-logged-in">
            <div class="not-logged-in-card">
                <div class="not-logged-in-icon">🎫</div>
                <h2>Chưa Đăng Nhập</h2>
                <p>Bạn cần đăng nhập để xem vé của mình.</p>
                <a href="/login" class="btn-login-link">Đăng Nhập Ngay</a>
            </div>
        </div>
    }
    else
    {
        var allTickets = BookingService.LayVeCuaToi();
        var filteredTickets = GetFilteredTickets(allTickets);
        var activeCount = allTickets.Count(v => v.TrangThai == "Dang Hoat Dong");
        var cancelledCount = allTickets.Count(v => v.TrangThai == "Da Huy");

        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1>🎫 Vé Của Tôi</h1>
                <p>Quản lý tất cả các vé tàu của bạn</p>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar">
            <div class="stats-bar-inner">
                <div class="mini-stat">
                    <span class="mini-stat-value">@allTickets.Count</span>
                    <span class="mini-stat-label">Tổng Vé</span>
                </div>
                <div class="mini-stat">
                    <span class="mini-stat-value active-text">@activeCount</span>
                    <span class="mini-stat-label">Đang Hoạt Động</span>
                </div>
                <div class="mini-stat">
                    <span class="mini-stat-value cancelled-text">@cancelledCount</span>
                    <span class="mini-stat-label">Đã Hủy</span>
                </div>
            </div>
        </div>

        <!-- Tab Filters -->
        <div class="tabs-section">
            <div class="tabs-container">
                <button class="tab-btn @(currentTab == "all" ? "active" : "")" @onclick='() => SetTab("all")'>
                    Tất Cả <span class="tab-badge">@allTickets.Count</span>
                </button>
                <button class="tab-btn @(currentTab == "active" ? "active" : "")" @onclick='() => SetTab("active")'>
                    Đang Hoạt Động <span class="tab-badge active-badge">@activeCount</span>
                </button>
                <button class="tab-btn @(currentTab == "cancelled" ? "active" : "")" @onclick='() => SetTab("cancelled")'>
                    Đã Hủy <span class="tab-badge cancelled-badge">@cancelledCount</span>
                </button>
            </div>
        </div>

        <!-- Message -->
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="message-section">
                <div class="alert @(isSuccess ? "alert-success" : "alert-error")">
                    @message
                </div>
            </div>
        }

        <!-- Tickets List -->
        <div class="tickets-section">
            @if (filteredTickets.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h3>Không có vé nào</h3>
                    <p>@GetEmptyMessage()</p>
                    @if (currentTab == "all")
                    {
                        <a href="/train-list" class="btn-book">Đặt Vé Ngay</a>
                    }
                </div>
            }
            else
            {
                <div class="tickets-grid">
                    @foreach (var ve in filteredTickets)
                    {
                        <div class="ticket-card @(ve.TrangThai == "Da Huy" ? "cancelled" : "")">
                            <!-- Ticket Type Badge -->
                            <div class="ticket-type-badge @(ve is VeVIP ? "vip" : "standard")">
                                @if (ve is VeVIP)
                                {
                                    <span>⭐ VIP</span>
                                }
                                else if (ve is VeThuong)
                                {
                                    <span>🎫 Thường</span>
                                }
                            </div>

                            <!-- Ticket Status -->
                            <div class="ticket-status @(ve.TrangThai == "Dang Hoat Dong" ? "status-active" : "status-cancelled")">
                                @ve.TrangThai
                            </div>

                            <!-- Ticket Header -->
                            <div class="ticket-header">
                                <span class="ticket-id">Mã Vé: @ve.MaVe.Substring(0, Math.Min(8, ve.MaVe.Length))...</span>
                            </div>

                            <!-- Route Info -->
                            @if (ve.ChuyenTau != null)
                            {
                                <div class="ticket-route">
                                    <div class="route-from">
                                        <span class="route-city">@(ve.ChuyenTau.GaDi?.TenGa ?? "N/A")</span>
                                    </div>
                                    <div class="route-arrow">
                                        <span class="arrow-line"></span>
                                        <span class="arrow-icon">🚂</span>
                                        <span class="arrow-line"></span>
                                    </div>
                                    <div class="route-to">
                                        <span class="route-city">@(ve.ChuyenTau.GaDen?.TenGa ?? "N/A")</span>
                                    </div>
                                </div>

                                <div class="ticket-time">
                                    <span>🕐 @ve.ChuyenTau.ThoiGianKhoiHanh.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            }

                            <!-- Ticket Details -->
                            <div class="ticket-details">
                                <div class="detail-item">
                                    <span class="detail-label">Toa</span>
                                    <span class="detail-value">@ve.MaToa</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Ghế</span>
                                    <span class="detail-value">@ve.ViTriGhe</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">Giá Vé</span>
                                    <span class="detail-value price">@ve.TinhGiaVe().ToString("N0") VND</span>
                                </div>
                            </div>

                            <!-- VIP multiplier info -->
                            @if (ve is VeVIP veVip)
                            {
                                <div class="vip-info">
                                    <span>Hệ số VIP: x@veVip.HeSoVip</span>
                                </div>
                            }

                            <!-- Cancel Button -->
                            @if (ve.TrangThai == "Dang Hoat Dong")
                            {
                                <div class="ticket-actions">
                                    <button class="btn-cancel" @onclick="() => CancelTicket(ve.MaVe)">
                                        ✕ Hủy Vé
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private string currentTab = "all";
    private string message = "";
    private bool isSuccess = false;

    private void SetTab(string tab)
    {
        currentTab = tab;
        message = "";
    }

    private List<VeTau> GetFilteredTickets(List<VeTau> allTickets)
    {
        return currentTab switch
        {
            "active" => allTickets.Where(v => v.TrangThai == "Dang Hoat Dong").ToList(),
            "cancelled" => allTickets.Where(v => v.TrangThai == "Da Huy").ToList(),
            _ => allTickets
        };
    }

    private string GetEmptyMessage()
    {
        return currentTab switch
        {
            "active" => "Bạn không có vé nào đang hoạt động.",
            "cancelled" => "Bạn chưa hủy vé nào.",
            _ => "Bạn chưa đặt vé nào. Hãy đặt vé ngay!"
        };
    }

    private void CancelTicket(string maVe)
    {
        var (thanhCong, thongBao) = BookingService.HuyVe(maVe);
        message = thongBao;
        isSuccess = thanhCong;
    }
}

<style>
    .my-tickets-page {
        background: #f8f9fa;
        min-height: 100vh;
        padding-bottom: 2rem;
    }

    /* Not Logged In */
    .not-logged-in {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }

    .not-logged-in-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0, 61, 122, 0.1);
        max-width: 450px;
        width: 100%;
        animation: fadeIn 0.6s ease-out;
    }

    .not-logged-in-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
    }

    .not-logged-in-card h2 {
        color: #003d7a;
        margin-bottom: 0.8rem;
        font-size: 1.6rem;
    }

    .not-logged-in-card p {
        color: #666;
        margin-bottom: 1.5rem;
    }

    .btn-login-link {
        display: inline-block;
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
        color: white;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        padding: 2.5rem 2rem;
        color: white;
    }

    .header-content {
        max-width: 1100px;
        margin: 0 auto;
        animation: slideDown 0.6s ease-out;
    }

    .header-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .header-content p {
        opacity: 0.9;
        font-size: 1rem;
    }

    /* Stats Bar */
    .stats-bar {
        max-width: 1100px;
        margin: -1.5rem auto 1.5rem;
        padding: 0 1rem;
        position: relative;
        z-index: 10;
    }

    .stats-bar-inner {
        background: white;
        border-radius: 12px;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-around;
        box-shadow: 0 4px 16px rgba(0, 61, 122, 0.1);
    }

    .mini-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
    }

    .mini-stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #003d7a;
    }

    .mini-stat-value.active-text {
        color: #28a745;
    }

    .mini-stat-value.cancelled-text {
        color: #dc3545;
    }

    .mini-stat-label {
        font-size: 0.8rem;
        color: #666;
    }

    /* Tabs */
    .tabs-section {
        max-width: 1100px;
        margin: 0 auto 1.5rem;
        padding: 0 1rem;
    }

    .tabs-container {
        display: flex;
        gap: 0.5rem;
        background: white;
        border-radius: 12px;
        padding: 0.5rem;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
    }

    .tab-btn {
        flex: 1;
        padding: 0.8rem 1rem;
        border: none;
        background: transparent;
        border-radius: 8px;
        font-weight: 600;
        color: #666;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .tab-btn:hover {
        background: #f0f5ff;
        color: #003d7a;
    }

    .tab-btn.active {
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
    }

    .tab-badge {
        background: rgba(0, 0, 0, 0.15);
        padding: 0.15rem 0.5rem;
        border-radius: 10px;
        font-size: 0.75rem;
    }

    .tab-btn.active .tab-badge {
        background: rgba(255, 255, 255, 0.25);
    }

    /* Message */
    .message-section {
        max-width: 1100px;
        margin: 0 auto 1rem;
        padding: 0 1rem;
    }

    .alert {
        padding: 0.8rem 1.2rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 12px;
        max-width: 1100px;
        margin: 0 auto;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        color: #003d7a;
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #666;
        margin-bottom: 1.5rem;
    }

    .btn-book {
        display: inline-block;
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-book:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
        color: white;
    }

    /* Tickets Grid */
    .tickets-section {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .tickets-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.5rem;
    }

    .ticket-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.1);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        animation: slideUp 0.5s ease-out;
        border-left: 4px solid #003d7a;
    }

    .ticket-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 61, 122, 0.15);
    }

    .ticket-card.cancelled {
        border-left-color: #dc3545;
        opacity: 0.8;
    }

    /* Type Badge */
    .ticket-type-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .ticket-type-badge.vip {
        background: linear-gradient(135deg, #ffd700 0%, #ffb300 100%);
        color: #333;
    }

    .ticket-type-badge.standard {
        background: #e8f4fd;
        color: #003d7a;
    }

    /* Ticket Status */
    .ticket-status {
        display: inline-block;
        padding: 0.25rem 0.7rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 0.8rem;
    }

    .status-active {
        background: #d4edda;
        color: #155724;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #721c24;
    }

    /* Ticket Header */
    .ticket-header {
        margin-bottom: 1rem;
    }

    .ticket-id {
        font-size: 0.85rem;
        color: #888;
        font-family: 'Courier New', monospace;
    }

    /* Route */
    .ticket-route {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.8rem;
        padding: 0.8rem 0;
    }

    .route-from,
    .route-to {
        flex: 1;
    }

    .route-city {
        font-size: 1rem;
        font-weight: 700;
        color: #003d7a;
    }

    .route-to {
        text-align: right;
    }

    .route-arrow {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        flex: 1;
        justify-content: center;
    }

    .arrow-line {
        height: 2px;
        width: 30px;
        background: #ccc;
    }

    .arrow-icon {
        font-size: 1.2rem;
    }

    /* Ticket Time */
    .ticket-time {
        color: #666;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px dashed #e0e0e0;
    }

    /* Ticket Details */
    .ticket-details {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .detail-label {
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        font-weight: 600;
    }

    .detail-value {
        font-size: 0.95rem;
        color: #333;
        font-weight: 600;
    }

    .detail-value.price {
        color: #003d7a;
        font-weight: 700;
    }

    /* VIP Info */
    .vip-info {
        background: linear-gradient(135deg, #fff8e1 0%, #fff3cd 100%);
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.8rem;
        color: #856404;
        font-weight: 600;
        margin-bottom: 1rem;
        display: inline-block;
    }

    /* Ticket Actions */
    .ticket-actions {
        padding-top: 1rem;
        border-top: 1px solid #f0f0f0;
    }

    .btn-cancel {
        width: 100%;
        padding: 0.7rem;
        border: 2px solid #dc3545;
        background: transparent;
        color: #dc3545;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.9rem;
    }

    .btn-cancel:hover {
        background: #dc3545;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .header-content h1 {
            font-size: 1.5rem;
        }

        .stats-bar-inner {
            padding: 1rem;
        }

        .tabs-container {
            flex-direction: column;
        }

        .tickets-grid {
            grid-template-columns: 1fr;
        }

        .ticket-details {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>
