@page "/checkout"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject ProjectTrainWeb.Services.ThanhToanDuyetService DuyetService
@inject NavigationManager NavigationManager

<div class="checkout-page">
    @* ===================== SUCCESS STATE (check FIRST — DatVe clears GheDaChon) ===================== *@
    @if (paymentSuccess && createdTicket != null)
    {
        @* ===================== SUCCESS STATE ===================== *@
        <div class="success-container">
            <div class="success-card">
                <div class="success-animation">
                    <div class="success-checkmark">✓</div>
                </div>
                <h2>Yêu Cầu Đã Gửi!</h2>
                <p class="success-message">@successMessage</p>

                <div class="ticket-info-box">
                    <div class="ticket-detail-row">
                        <span class="ticket-label">Mã Vé:</span>
                        <span class="ticket-value highlight">@createdTicket.MaVe.Substring(0, 8).ToUpper()</span>
                    </div>
                    <div class="ticket-detail-row">
                        <span class="ticket-label">Chuyến:</span>
                        <span class="ticket-value">@BookingService.ChuyenTauDaChon?.GaDi?.TenGa → @BookingService.ChuyenTauDaChon?.GaDen?.TenGa</span>
                    </div>
                    <div class="ticket-detail-row">
                        <span class="ticket-label">Loại Vé:</span>
                        <span class="ticket-value">@(selectedLoaiVe == "vip" ? "Vé VIP" : "Vé Thường")</span>
                    </div>
                    <div class="ticket-detail-row">
                        <span class="ticket-label">Tổng Tiền:</span>
                        <span class="ticket-value highlight">@TinhTongCong().ToString("N0") VND</span>
                    </div>
                </div>

                <div class="success-actions">
                    <button class="btn-primary" @onclick='() => NavigationManager.NavigateTo("/booking-history")'>
                        🎫 Xem Lịch Sử Đặt Vé
                    </button>
                    <button class="btn-secondary" @onclick='() => NavigationManager.NavigateTo("/")'>
                        🏠 Về Trang Chủ
                    </button>
                </div>
            </div>
        </div>
    }
    else if (BookingService.ChuyenTauDaChon == null)
    {
        @* ===================== EDGE CASE: No train selected ===================== *@
        <div class="empty-state-container">
            <div class="empty-state-card">
                <div class="empty-icon">🚂</div>
                <h2>Chưa Chọn Chuyến Tàu</h2>
                <p>Bạn chưa chọn chuyến tàu nào. Vui lòng quay lại để chọn chuyến tàu trước khi thanh toán.</p>
                <button class="btn-primary" @onclick='() => NavigationManager.NavigateTo("/search-trains")'>
                    ← Quay Lại Chọn Chuyến
                </button>
            </div>
        </div>
    }
    else if (BookingService.GheDaChon == null || BookingService.GheDaChon.Count == 0)
    {
        @* ===================== EDGE CASE: No seats selected ===================== *@
        <div class="empty-state-container">
            <div class="empty-state-card">
                <div class="empty-icon">💺</div>
                <h2>Chưa Chọn Ghế Ngồi</h2>
                <p>Bạn chưa chọn ghế ngồi nào. Vui lòng quay lại để chọn ghế trước khi thanh toán.</p>
                <button class="btn-primary" @onclick="GoBackToSeatSelection">
                    ← Quay Lại Chọn Ghế
                </button>
            </div>
        </div>
    }
    else
    {
        @* ===================== MAIN CHECKOUT FLOW ===================== *@

        @* -- Progress Steps Bar -- *@
        <section class="checkout-header">
            <div class="header-container">
                <h1>Thanh Toán</h1>
                <div class="progress-steps">
                    <div class="step completed">
                        <span class="step-number">✓</span>
                        <span class="step-label">Chọn Chuyến</span>
                    </div>
                    <div class="step-line completed-line"></div>
                    <div class="step completed">
                        <span class="step-number">✓</span>
                        <span class="step-label">Chọn Ghế</span>
                    </div>
                    <div class="step-line completed-line"></div>
                    <div class="step active">
                        <span class="step-number">3</span>
                        <span class="step-label">Thanh Toán</span>
                    </div>
                </div>
            </div>
        </section>

        @* -- Main Content: Left + Right columns -- *@
        <div class="checkout-main">

            @* ========== LEFT COLUMN - Forms ========== *@
            <section class="checkout-form-section">

                @* --- Thong Tin Hanh Khach --- *@
                <div class="form-card">
                    <h2>
                        <span class="section-icon">👤</span>
                        Thông Tin Hành Khách
                    </h2>

                    @if (BookingService.DaDangNhap && BookingService.HanhKhachHienTai != null)
                    {
                        <div class="logged-in-info">
                            <div class="info-badge">
                                <span class="badge-icon">✓</span>
                                Đã đăng nhập
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Họ Và Tên</label>
                                    <input type="text" class="form-input readonly-input" value="@BookingService.HanhKhachHienTai.HoTen" readonly />
                                </div>
                                <div class="form-group">
                                    <label>Số Điện Thoại</label>
                                    <input type="text" class="form-input readonly-input" value="@BookingService.HanhKhachHienTai.SoDienThoai" readonly />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="not-logged-in">
                            <div class="login-prompt">
                                <span class="prompt-icon">⚠️</span>
                                <div>
                                    <p>Bạn chưa đăng nhập. Vui lòng <a href="/login" class="login-link">đăng nhập</a> để tự động điền thông tin và đặt vé.</p>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="guestName">Họ Và Tên *</label>
                                    <input type="text" id="guestName" class="form-input" placeholder="Nhập họ và tên" @bind="guestName" />
                                </div>
                                <div class="form-group">
                                    <label for="guestPhone">Số Điện Thoại *</label>
                                    <input type="tel" id="guestPhone" class="form-input" placeholder="Nhập số điện thoại" @bind="guestPhone" />
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* --- Phương Thức Thanh Toán: Chuyển Khoản Ngân Hàng --- *@
                <div class="form-card">
                    <h2>
                        <span class="section-icon">💳</span>
                        Thanh Toán Chuyển Khoản
                    </h2>

                    <div class="bank-transfer-info">
                        <div class="qr-section">
                            @{
                                var cauHinh = DuyetService.LayCauHinhThanhToan();
                            }
                            @if (!string.IsNullOrEmpty(cauHinh.HinhQR))
                            {
                                <div class="qr-code">
                                    <img src="@cauHinh.HinhQR" alt="QR Thanh Toán" style="max-width: 200px; border-radius: 8px;" />
                                </div>
                            }
                            else
                            {
                                <div class="qr-placeholder">
                                    <span class="qr-icon">📱</span>
                                    <p>Quét mã QR để thanh toán</p>
                                </div>
                            }
                        </div>

                        <div class="bank-details">
                            <h4>Thông Tin Chuyển Khoản</h4>
                            <div class="bank-detail-row">
                                <span class="bank-label">Ngân hàng:</span>
                                <span class="bank-value">@cauHinh.TenNganHang</span>
                            </div>
                            <div class="bank-detail-row">
                                <span class="bank-label">Số tài khoản:</span>
                                <span class="bank-value account-number">@cauHinh.SoTaiKhoan</span>
                            </div>
                            <div class="bank-detail-row">
                                <span class="bank-label">Chủ tài khoản:</span>
                                <span class="bank-value">@cauHinh.TenChuTaiKhoan</span>
                            </div>
                            <div class="bank-detail-row">
                                <span class="bank-label">Số tiền:</span>
                                <span class="bank-value price-highlight">@TinhTongCong().ToString("N0") VND</span>
                            </div>
                            <div class="bank-detail-row">
                                <span class="bank-label">Nội dung CK:</span>
                                <span class="bank-value">THANHTOAN @(createdTicket?.MaVe.Substring(0, 8).ToUpper() ?? "MAVE")</span>
                            </div>
                        </div>
                    </div>

                    <div class="transfer-note">
                        <p>⚠️ <strong>Lưu ý:</strong> Sau khi chuyển khoản, bấm nút "Gửi Yêu Cầu Xác Nhận" bên dưới. Admin sẽ kiểm tra và duyệt thanh toán của bạn.</p>
                    </div>
                </div>

                @* --- Ma Khuyen Mai --- *@
                <div class="form-card">
                    <h2>
                        <span class="section-icon">🎁</span>
                        Mã Khuyến Mãi
                    </h2>

                    <div class="voucher-input-group">
                        <input type="text" class="form-input" placeholder="Nhập mã khuyến mãi" @bind="voucherCode" />
                        <button class="btn-apply" @onclick="ApplyVoucher" disabled="@voucherApplied">
                            @(voucherApplied ? "Đã Áp Dụng" : "Áp Dụng")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(voucherMessage))
                    {
                        <div class="voucher-message @(voucherApplied ? "success" : "error")">
                            @voucherMessage
                        </div>
                    }

                    @if (voucherApplied && discountAmount > 0)
                    {
                        <div class="discount-applied">
                            <span class="discount-icon">🏷️</span>
                            <span>Giảm giá: <strong>-@discountAmount.ToString("N0") VND</strong></span>
                            <button class="btn-remove-voucher" @onclick="RemoveVoucher">✕</button>
                        </div>
                    }
                </div>

            </section>

            @* ========== RIGHT COLUMN - Order Summary ========== *@
            <aside class="order-summary-sticky">
                <div class="summary-card">
                    <h3>
                        <span class="section-icon">📋</span>
                        Tổng Kết Đơn Hàng
                    </h3>

                    @* -- Train Info -- *@
                    <div class="summary-section">
                        <div class="trip-summary">
                            <div class="trip-line">
                                <span class="trip-station">@BookingService.ChuyenTauDaChon?.GaDi?.TenGa</span>
                                <span class="trip-arrow">→</span>
                                <span class="trip-station">@BookingService.ChuyenTauDaChon?.GaDen?.TenGa</span>
                            </div>
                            <p class="trip-time">
                                🕐 @BookingService.ChuyenTauDaChon?.ThoiGianKhoiHanh.ToString("dd/MM/yyyy HH:mm")
                                - @BookingService.ChuyenTauDaChon?.ThoiGianDenDu.ToString("HH:mm dd/MM")
                            </p>
                            <p class="trip-id">Mã chuyến: #@BookingService.ChuyenTauDaChon?.MaChuyen</p>
                        </div>
                    </div>

                    @* -- Selected Seats -- *@
                    <div class="summary-section">
                        <h4>💺 Ghế Đã Chọn (@BookingService.GheDaChon.Count ghế)</h4>
                        <div class="seats-list">
                            @foreach (var ghe in BookingService.GheDaChon)
                            {
                                <div class="seat-item">
                                    <span class="seat-badge">Ghế @ghe.MaGhe</span>
                                    <span class="seat-price">@ghe.GiaCoBan.ToString("N0") VND</span>
                                </div>
                            }
                        </div>
                    </div>

                    @* -- Loai Ve Selector -- *@
                    <div class="summary-section">
                        <h4>🎫 Loại Vé</h4>
                        <div class="ticket-type-selector">
                            <label class="ticket-type-option @(selectedLoaiVe == "ordinary" ? "selected" : "")">
                                <input type="radio" name="ticketType" value="ordinary"
                                       checked="@(selectedLoaiVe == "ordinary")"
                                       @onchange='() => SelectLoaiVe("ordinary")' />
                                <div class="ticket-type-content">
                                    <strong>Vé Thường</strong>
                                    <span class="ticket-type-desc">Giá gốc, không phụ thu</span>
                                </div>
                            </label>
                            <label class="ticket-type-option @(selectedLoaiVe == "vip" ? "selected" : "")">
                                <input type="radio" name="ticketType" value="vip"
                                       checked="@(selectedLoaiVe == "vip")"
                                       @onchange='() => SelectLoaiVe("vip")' />
                                <div class="ticket-type-content">
                                    <strong>Vé VIP</strong>
                                    <span class="ticket-type-desc">Hệ số x1.3, dịch vụ cao cấp</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    @* -- Price Breakdown -- *@
                    <div class="summary-section price-breakdown">
                        <div class="price-row">
                            <span>Tạm tính (@BookingService.GheDaChon.Count vé):</span>
                            <span class="price">@TinhTamTinh().ToString("N0") VND</span>
                        </div>
                        @if (selectedLoaiVe == "vip")
                        {
                            <div class="price-row vip-row">
                                <span>Phụ thu VIP (x1.3):</span>
                                <span class="price">+@((TinhTamTinhVIP() - TinhTamTinh()).ToString("N0")) VND</span>
                            </div>
                        }
                        @if (discountAmount > 0)
                        {
                            <div class="price-row discount">
                                <span>Giảm giá:</span>
                                <span class="price">-@discountAmount.ToString("N0") VND</span>
                            </div>
                        }
                        <div class="price-row divider"></div>
                        <div class="price-row total">
                            <span>Tổng Cộng:</span>
                            <span class="price-total">@TinhTongCong().ToString("N0") VND</span>
                        </div>
                    </div>

                    @* -- Error Message -- *@
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="error-box">
                            <span>❌</span> @errorMessage
                        </div>
                    }

                    @* -- Confirm Button -- *@
                    <div class="summary-actions">
                        <button class="btn-confirm"
                                disabled="@isProcessing"
                                @onclick="ConfirmPayment">
                            @if (isProcessing)
                            {
                                <span class="spinner"></span>
                                <span>Đang Xử Lý...</span>
                            }
                            else
                            {
                                <span class="btn-icon">✓</span>
                                <span>Gửi Yêu Cầu Xác Nhận</span>
                            }
                        </button>
                        <button class="btn-back-summary" @onclick="GoBack">
                            ← Quay Lại Chọn Ghế
                        </button>
                    </div>

                    <p class="summary-note">
                        Sau khi gửi yêu cầu, Admin sẽ kiểm tra và duyệt thanh toán. Bạn có thể theo dõi tại trang Lịch Sử Đặt Vé.
                    </p>
                </div>
            </aside>
        </div>
    }
</div>

@code {
    // -- State fields --
    private string paymentMethod = "transfer";
    private string selectedLoaiVe = "ordinary";
    private string voucherCode = "";
    private bool voucherApplied = false;
    private string voucherMessage = "";
    private double discountAmount = 0;

    private string guestName = "";
    private string guestPhone = "";

    private bool isProcessing = false;
    private bool paymentSuccess = false;
    private string successMessage = "";
    private string errorMessage = "";
    private VeTau? createdTicket = null;

    // -- Lifecycle --
    protected override void OnInitialized()
    {
        // Default loai ve from service if set
        if (!string.IsNullOrEmpty(BookingService.LoaiVeDaChon))
        {
            selectedLoaiVe = BookingService.LoaiVeDaChon;
        }
    }

    // -- Price calculations --
    private double TinhTamTinh()
    {
        if (BookingService.GheDaChon == null) return 0;
        return BookingService.GheDaChon.Sum(g => g.GiaCoBan);
    }

    private double TinhTamTinhVIP()
    {
        return TinhTamTinh() * 1.3;
    }

    private double TinhSubTotal()
    {
        return selectedLoaiVe == "vip" ? TinhTamTinhVIP() : TinhTamTinh();
    }

    private double TinhTongCong()
    {
        double total = TinhSubTotal() - discountAmount;
        return total > 0 ? total : 0;
    }

    private void SelectLoaiVe(string loai)
    {
        selectedLoaiVe = loai;
        BookingService.LoaiVeDaChon = loai;
        // Recalculate discount if voucher was applied (based on new subtotal)
        if (voucherApplied && !string.IsNullOrEmpty(voucherCode))
        {
            // Keep existing discount, don't re-apply
        }
    }

    // -- Voucher --
    private void ApplyVoucher()
    {
        if (string.IsNullOrWhiteSpace(voucherCode))
        {
            voucherMessage = "Vui lòng nhập mã khuyến mãi.";
            voucherApplied = false;
            discountAmount = 0;
            return;
        }

        double giaGoc = TinhSubTotal();
        var (thanhCong, tienGiam, thongBao) = BookingService.ApDungKhuyenMai(voucherCode, giaGoc);

        if (thanhCong)
        {
            discountAmount = tienGiam;
            voucherMessage = "✓ " + thongBao;
            voucherApplied = true;
        }
        else
        {
            discountAmount = 0;
            voucherMessage = "✗ " + thongBao;
            voucherApplied = false;
        }
    }

    private void RemoveVoucher()
    {
        voucherCode = "";
        voucherApplied = false;
        voucherMessage = "";
        discountAmount = 0;
    }

    // -- Confirm Payment --
    private async Task ConfirmPayment()
    {
        errorMessage = "";

        // Validation
        if (!BookingService.DaDangNhap)
        {
            errorMessage = "Vui lòng đăng nhập trước khi đặt vé!";
            return;
        }

        if (BookingService.ChuyenTauDaChon == null)
        {
            errorMessage = "Không tìm thấy chuyến tàu đã chọn!";
            return;
        }

        if (BookingService.GheDaChon == null || BookingService.GheDaChon.Count == 0)
        {
            errorMessage = "Không có ghế nào được chọn!";
            return;
        }

        isProcessing = true;
        StateHasChanged();

        // Simulate processing delay
        await Task.Delay(1500);

        // Tạo vé (chưa thanh toán)
        var (thanhCong, thongBao, ve) = BookingService.DatVe(selectedLoaiVe);

        if (thanhCong && ve != null)
        {
            // Gửi yêu cầu duyệt thanh toán đến Admin
            var (guiOk, guiMsg, yeuCau) = DuyetService.GuiYeuCauThanhToan(
                ve, BookingService.HanhKhachHienTai!, TinhTongCong());

            paymentSuccess = true;
            successMessage = "Yêu cầu thanh toán đã được gửi đến Admin. Vui lòng chờ duyệt. Bạn có thể theo dõi trạng thái tại trang Lịch Sử Đặt Vé.";
            createdTicket = ve;
        }
        else
        {
            errorMessage = thongBao;
        }

        isProcessing = false;
        StateHasChanged();
    }

    // -- Navigation --
    private void GoBack()
    {
        GoBackToSeatSelection();
    }

    private void GoBackToSeatSelection()
    {
        var maChuyen = BookingService.ChuyenTauDaChon?.MaChuyen;
        if (maChuyen != null)
        {
            NavigationManager.NavigateTo($"/seat-selection/{maChuyen}");
        }
        else
        {
            NavigationManager.NavigateTo("/search-trains");
        }
    }
}

<style>
    /* ==================== BASE ==================== */
    .checkout-page {
        background: #f8f9fa;
        min-height: 100vh;
        padding-bottom: 3rem;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* ==================== EMPTY STATE ==================== */
    .empty-state-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }

    .empty-state-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,61,122,0.1);
        max-width: 500px;
        width: 100%;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state-card h2 {
        color: #003d7a;
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .empty-state-card p {
        color: #666;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    /* ==================== SUCCESS STATE ==================== */
    .success-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }

    .success-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,61,122,0.1);
        max-width: 550px;
        width: 100%;
        animation: fadeInUp 0.6s ease;
    }

    .success-animation {
        margin-bottom: 1.5rem;
    }

    .success-checkmark {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        font-size: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        animation: scaleIn 0.5s ease;
    }

    .success-card h2 {
        color: #28a745;
        margin-bottom: 0.5rem;
        font-size: 1.8rem;
    }

    .success-message {
        color: #666;
        margin-bottom: 2rem;
    }

    .ticket-info-box {
        background: #f8f9fa;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        text-align: left;
    }

    .ticket-detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 0;
        border-bottom: 1px solid #eee;
    }

    .ticket-detail-row:last-child {
        border-bottom: none;
    }

    .ticket-label {
        color: #666;
        font-weight: 500;
    }

    .ticket-value {
        font-weight: 600;
        color: #333;
    }

    .ticket-value.highlight {
        color: #003d7a;
        font-size: 1.05rem;
    }

    .success-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    /* ==================== HEADER & PROGRESS ==================== */
    .checkout-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        padding: 2rem 1rem;
    }

    .header-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .checkout-header h1 {
        margin-bottom: 2rem;
        font-size: 2rem;
        text-align: center;
    }

    .progress-steps {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
    }

    .step {
        display: flex;
