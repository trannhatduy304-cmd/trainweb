        font-size: 1.1rem;
        font-weight: 700;
        color: #003d7a;
    }

    .route-city {
        font-size: 0.85rem;
        color: #888;
        margin-top: 0.2rem;
    }

    .route-arrow {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex: 0.8;
        justify-content: center;
    }

    .arrow-line {
        width: 40px;
        height: 2px;
        background: linear-gradient(to right, #003d7a, #0077cc);
    }

    .arrow-icon {
        font-size: 1.5rem;
    }

    /* Details Grid */
    .details-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    .detail-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 61, 122, 0.1);
    }

    .detail-icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .detail-label {
        font-size: 0.8rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    .detail-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #333;
    }

    .detail-value.code {
        font-family: 'Courier New', monospace;
        color: #003d7a;
        font-size: 0.85rem;
    }

    /* Price Section */
    .price-section {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        border: 1px solid #e0e0e0;
    }

    .price-details {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
