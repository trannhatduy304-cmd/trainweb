@page "/ticket-lookup"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject NavigationManager NavigationManager

@* TicketLookup Page - Trang Tra Cuu Ve Tau *@

<div class="ticket-lookup-page">
    <!-- Header -->
    <section class="lookup-header">
        <div class="header-container">
            <div class="header-icon">🔍</div>
            <h1>Tra Cứu Vé Tàu</h1>
            <p>Nhập mã vé để xem thông tin chi tiết vé tàu của bạn</p>
        </div>
    </section>

    <!-- Search Section -->
    <section class="search-section">
        <div class="search-container">
            <div class="search-card">
                <div class="search-input-group">
                    <div class="input-wrapper">
                        <span class="input-icon">🎫</span>
                        <input type="text" class="search-input" placeholder="Nhập mã vé (VD: abc12345...)"
                               @bind="maVeTimKiem" @bind:event="oninput"
                               @onkeydown="HandleKeyPress" />
                    </div>
                    <button class="btn-search" @onclick="TimKiemVe" disabled="@dangTimKiem">
                        @if (dangTimKiem)
                        {
                            <span class="spinner"></span>
                            <span>Đang tìm...</span>
                        }
                        else
                        {
                            <span>🔍</span>
                            <span>Tra Cứu</span>
                        }
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(thongBaoLoi))
                {
                    <div class="alert-message error">
                        <span class="alert-icon">⚠️</span>
                        <span>@thongBaoLoi</span>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Result Section -->
    @if (veTimThay != null)
    {
        <section class="result-section">
            <div class="result-container">
                <!-- Ticket Card -->
                <div class="ticket-card">
                    <!-- Ticket Header -->
                    <div class="ticket-header">
                        <div class="ticket-header-left">
                            <span class="ticket-badge @(veTimThay is VeVIP ? "vip" : "thuong")">
                                @(veTimThay is VeVIP ? "⭐ VÉ VIP" : "🎫 VÉ THƯỜNG")
                            </span>
                            <h2>Thông Tin Vé Tàu</h2>
                        </div>
                        <div class="ticket-status @(veTimThay.TrangThai == "Dang Hoat Dong" ? "active" : "cancelled")">
                            <span class="status-dot"></span>
                            <span>@veTimThay.TrangThai</span>
                        </div>
                    </div>

                    <!-- Ticket Body -->
                    <div class="ticket-body">
                        <!-- Route Info -->
                        <div class="route-info-card">
                            <div class="route-from">
                                <span class="route-label">Ga Đi</span>
                                <span class="route-station">@(veTimThay.ChuyenTau?.GaDi?.TenGa ?? "N/A")</span>
                                <span class="route-city">@(veTimThay.ChuyenTau?.GaDi?.ThanhPho ?? "")</span>
                            </div>
                            <div class="route-arrow">
                                <div class="arrow-line"></div>
                                <span class="arrow-icon">🚂</span>
                                <div class="arrow-line"></div>
                            </div>
                            <div class="route-to">
                                <span class="route-label">Ga Đến</span>
                                <span class="route-station">@(veTimThay.ChuyenTau?.GaDen?.TenGa ?? "N/A")</span>
                                <span class="route-city">@(veTimThay.ChuyenTau?.GaDen?.ThanhPho ?? "")</span>
                            </div>
                        </div>

                        <!-- Details Grid -->
                        <div class="details-grid">
                            <div class="detail-item">
                                <span class="detail-icon">📋</span>
                                <span class="detail-label">Mã Vé</span>
                                <span class="detail-value code">@veTimThay.MaVe.Substring(0, Math.Min(8, veTimThay.MaVe.Length))...</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-icon">🚃</span>
                                <span class="detail-label">Mã Chuyến</span>
                                <span class="detail-value">CT-@(veTimThay.ChuyenTau?.MaChuyen ?? 0)</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-icon">🪑</span>
                                <span class="detail-label">Toa / Ghế</span>
                                <span class="detail-value">@veTimThay.MaToa / Ghế @veTimThay.ViTriGhe</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-icon">📅</span>
                                <span class="detail-label">Ngày Đặt</span>
                                <span class="detail-value">@veTimThay.NgayDat.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-icon">🕐</span>
                                <span class="detail-label">Khởi Hành</span>
                                <span class="detail-value">@(veTimThay.ChuyenTau?.ThoiGianKhoiHanh.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-icon">🕑</span>
                                <span class="detail-label">Đến Dự Kiến</span>
                                <span class="detail-value">@(veTimThay.ChuyenTau?.ThoiGianDenDu.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</span>
                            </div>
                        </div>

                        <!-- Ticket Type & Price Section -->
                        <div class="price-section">
                            <div class="price-details">
                                <div class="price-row">
                                    <span>Loại Vé:</span>
                                    <span class="@(veTimThay is VeVIP ? "text-vip" : "text-thuong")">
                                        @(veTimThay is VeVIP ? "Vé VIP" : "Vé Thường")
                                    </span>
                                </div>
                                <div class="price-row">
                                    <span>Giá Cơ Bản:</span>
                                    <span>@veTimThay.GiaCoBanGhe.ToString("N0") VND</span>
                                </div>
                                @if (veTimThay is VeVIP veVip)
                                {
                                    <div class="price-row vip-highlight">
                                        <span>Hệ Số VIP:</span>
                                        <span class="text-vip">x@veVip.HeSoVip</span>
                                    </div>
                                }
                                <div class="price-divider"></div>
                                <div class="price-row total">
                                    <span>Tổng Giá Vé:</span>
                                    <span class="price-total">@veTimThay.TinhGiaVe().ToString("N0") VND</span>
                                </div>
                            </div>
                        </div>

                        <!-- Passenger Info -->
                        @if (veTimThay.HanhKhach != null)
                        {
                            <div class="passenger-info">
                                <h3>Thông Tin Hành Khách</h3>
                                <div class="passenger-details">
                                    <div class="passenger-item">
                                        <span class="p-icon">👤</span>
                                        <span class="p-label">Họ Tên:</span>
                                        <span class="p-value">@veTimThay.HanhKhach.HoTen</span>
                                    </div>
                                    <div class="passenger-item">
                                        <span class="p-icon">📞</span>
                                        <span class="p-label">SDT:</span>
                                        <span class="p-value">@veTimThay.HanhKhach.SoDienThoai</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Ticket Footer -->
                    <div class="ticket-footer">
                        <p>⚠️ Vui lòng mang theo CMND/CCCD khi lên tàu. Vé chỉ có giá trị cho chuyến tàu đã đăng ký.</p>
                    </div>
                </div>
            </div>
        </section>
    }

    <!-- Quick Tips -->
    <section class="tips-section">
        <div class="tips-container">
            <h3>Hướng Dẫn Tra Cứu</h3>
            <div class="tips-grid">
                <div class="tip-card">
                    <span class="tip-icon">1️⃣</span>
                    <p>Nhập mã vé bạn nhận được khi đặt vé thành công</p>
                </div>
                <div class="tip-card">
                    <span class="tip-icon">2️⃣</span>
                    <p>Nhấn nút "Tra Cứu" hoặc phím Enter để tìm kiếm</p>
                </div>
                <div class="tip-card">
                    <span class="tip-icon">3️⃣</span>
                    <p>Xem thông tin chi tiết vé, tuyến đường và giá vé</p>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private string maVeTimKiem = "";
    private VeTau? veTimThay;
    private string thongBaoLoi = "";
    private bool dangTimKiem = false;

    private async Task TimKiemVe()
    {
        thongBaoLoi = "";
        veTimThay = null;

        if (string.IsNullOrWhiteSpace(maVeTimKiem))
        {
            thongBaoLoi = "Vui lòng nhập mã vé để tra cứu!";
            return;
        }

        dangTimKiem = true;
        StateHasChanged();

        // Mo phong thoi gian xu ly
        await Task.Delay(500);

        veTimThay = BookingService.TraCuuVe(maVeTimKiem.Trim());

        if (veTimThay == null)
        {
            thongBaoLoi = $"Không tìm thấy vé với mã \"{maVeTimKiem}\". Vui lòng kiểm tra lại!";
        }

        dangTimKiem = false;
    }

    private async Task HandleKeyPress(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await TimKiemVe();
        }
    }
}

<style>
    .ticket-lookup-page {
        background: #f8f9fa;
        min-height: 100vh;
    }

    /* Header */
    .lookup-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        padding: 3rem 1rem;
        text-align: center;
    }

    .header-container {
        max-width: 800px;
        margin: 0 auto;
        animation: fadeDown 0.6s ease-out;
    }

    .header-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .lookup-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .lookup-header p {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    @@keyframes fadeDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Search Section */
    .search-section {
        margin-top: -2rem;
        position: relative;
        z-index: 10;
        padding: 0 1rem;
    }

    .search-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .search-card {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(0, 61, 122, 0.15);
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .search-input-group {
        display: flex;
        gap: 1rem;
        align-items: stretch;
    }

    .input-wrapper {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        font-size: 1.2rem;
        z-index: 1;
    }

    .search-input {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: #003d7a;
        background: #f0f5ff;
        box-shadow: 0 0 8px rgba(0, 61, 122, 0.2);
    }

    .btn-search {
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
    }

    .btn-search:hover:not(:disabled) {
        background: linear-gradient(135deg, #002d5a 0%, #003d7a 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
    }

    .btn-search:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .alert-message {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
    }

    .alert-message.error {
        background: #fff3f3;
        color: #dc3545;
        border-left: 4px solid #dc3545;
    }

    .alert-icon {
        font-size: 1.1rem;
    }

    /* Result Section */
    .result-section {
        padding: 2rem 1rem;
    }

    .result-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .ticket-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 61, 122, 0.12);
        overflow: hidden;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: scale(0.98); }
        to { opacity: 1; transform: scale(1); }
    }

    /* Ticket Header */
    .ticket-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ticket-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .ticket-header h2 {
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0;
    }

    .ticket-badge {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .ticket-badge.vip {
        background: linear-gradient(135deg, #ff9800, #f57c00);
        color: white;
    }

    .ticket-badge.thuong {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 1px solid rgba(255,255,255,0.4);
    }

    .ticket-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .ticket-status.active {
        background: rgba(40, 167, 69, 0.2);
        color: #90ee90;
    }

    .ticket-status.cancelled {
        background: rgba(220, 53, 69, 0.2);
        color: #ff8a8a;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .ticket-status.active .status-dot {
        background: #90ee90;
    }

    .ticket-status.cancelled .status-dot {
        background: #ff8a8a;
        animation: none;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    /* Ticket Body */
    .ticket-body {
        padding: 2rem;
    }

    /* Route Info */
    .route-info-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #f0f5ff;
        border-radius: 12px;
        padding: 1.5rem 2rem;
        margin-bottom: 2rem;
    }

    .route-from, .route-to {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        flex: 1;
    }

    .route-label {
        font-size: 0.8rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.3rem;
    }

