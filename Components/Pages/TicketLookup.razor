    .tips-section {
        padding: 3rem 1rem;
    }

    .tips-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .tips-container h3 {
        color: #003d7a;
        text-align: center;
        font-size: 1.3rem;
        margin-bottom: 1.5rem;
    }

    .tips-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .tip-card {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
        transition: all 0.3s ease;
    }

    .tip-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0, 61, 122, 0.15);
    }

    .tip-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 0.8rem;
    }

    .tip-card p {
        color: #555;
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0;
    }

    @@media (max-width: 768px) {
        .lookup-header h1 {
            font-size: 1.6rem;
        }

        .search-input-group {
            flex-direction: column;
        }

        .route-info-card {
            flex-direction: column;
            gap: 1rem;
        }

        .route-arrow {
            transform: rotate(90deg);
        }

        .details-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .passenger-details {
            grid-template-columns: 1fr;
        }

        .tips-grid {
            grid-template-columns: 1fr;
        }

        .ticket-header {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .ticket-header-left {
            flex-direction: column;
        }
    }
</style>
