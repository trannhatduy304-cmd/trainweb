    }

    .sort-btn.active {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        border-color: #003d7a;
    }

    .sort-icon {
        font-size: 1rem;
    }

    /* Train Cards Container */
    .train-cards-container {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid #e0e0e0;
    }

    .pagination-btn {
        min-width: 40px;
        height: 40px;
        border: 1px solid #ddd;
        background: white;
        border-radius: 8px;
