    }

    .pagination-dots {
        color: #999;
    }

    @@media (max-width: 768px) {
        .header-container {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }

        .search-summary h1 {
            font-size: 1.5rem;
        }

        .sort-bar {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .sort-options {
            width: 100%;
        }

        .sort-btn {
            flex: 1;
            justify-content: center;
        }
