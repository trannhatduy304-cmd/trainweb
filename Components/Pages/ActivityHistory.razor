@page "/activity-history"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject NavigationManager NavigationManager

<div class="history-page">
    @if (!BookingService.DaDangNhap)
    {
        <!-- Not Logged In -->
        <div class="not-logged-in">
            <div class="not-logged-in-card">
                <div class="not-logged-in-icon">📋</div>
                <h2>Chưa Đăng Nhập</h2>
                <p>Bạn cần đăng nhập để xem lịch sử hoạt động.</p>
                <a href="/login" class="btn-login-link">Đăng Nhập Ngay</a>
            </div>
        </div>
    }
    else
    {
        var historyList = BookingService.LayLichSuCuaToi();

        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <h1>📋 Lịch Sử Hoạt Động</h1>
                <p>Theo dõi tất cả hoạt động của bạn trên hệ thống</p>
            </div>
        </div>

        <!-- Summary Bar -->
        <div class="summary-bar">
            <div class="summary-inner">
                <div class="summary-item">
                    <span class="summary-icon">📊</span>
                    <span class="summary-text">Tổng: <strong>@historyList.Count</strong> hoạt động</span>
                </div>
                <div class="summary-item">
                    <span class="summary-icon login-icon">🔑</span>
                    <span class="summary-text">Dang Nhap: <strong>@historyList.Count(h => h.HanhDong == "Dang Nhap")</strong></span>
                </div>
                <div class="summary-item">
                    <span class="summary-icon booking-icon">🎫</span>
                    <span class="summary-text">Dat Ve: <strong>@historyList.Count(h => h.HanhDong == "Dat Ve")</strong></span>
                </div>
                <div class="summary-item">
                    <span class="summary-icon cancel-icon">❌</span>
                    <span class="summary-text">Huy Ve: <strong>@historyList.Count(h => h.HanhDong == "Huy Ve")</strong></span>
                </div>
            </div>
        </div>

        <!-- Timeline Section -->
        <div class="timeline-section">
            @if (historyList.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h3>Chưa có hoạt động nào</h3>
                    <p>Lịch sử hoạt động của bạn sẽ được hiển thị tại đây.</p>
                </div>
            }
            else
            {
                <div class="timeline">
                    @foreach (var item in historyList)
                    {
                        var colorClass = GetActionColorClass(item.HanhDong);
                        var icon = GetActionIcon(item.HanhDong);

                        <div class="timeline-item">
                            <div class="timeline-line"></div>
                            <div class="timeline-dot @colorClass">
                                <span>@icon</span>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-card">
                                    <div class="timeline-card-header">
                                        <span class="action-badge @colorClass">@item.HanhDong</span>
                                        <span class="timeline-time">@item.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")</span>
                                    </div>
                                    <div class="timeline-card-body">
                                        @if (!string.IsNullOrEmpty(item.ChiTiet))
                                        {
                                            <p class="timeline-detail">@item.ChiTiet</p>
                                        }
                                        else
                                        {
                                            <p class="timeline-detail muted">Không có chi tiết thêm.</p>
                                        }
                                    </div>
                                    <div class="timeline-card-footer">
                                        <span class="timeline-user">👤 @item.NguoiThucHien</span>
                                        <span class="timeline-relative">@GetRelativeTime(item.ThoiGian)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private string GetActionColorClass(string hanhDong)
    {
        return hanhDong switch
        {
            "Dang Nhap" => "color-blue",
            "Dang Xuat" => "color-blue",
            "Dat Ve" => "color-green",
            "Huy Ve" => "color-red",
            "Dang Ky" => "color-purple",
            "Cap Nhat" => "color-orange",
            _ => "color-gray"
        };
    }

    private string GetActionIcon(string hanhDong)
    {
        return hanhDong switch
        {
            "Dang Nhap" => "🔑",
            "Dang Xuat" => "🚪",
            "Dat Ve" => "🎫",
            "Huy Ve" => "❌",
            "Dang Ky" => "📝",
            "Cap Nhat" => "✏️",
            _ => "📌"
        };
    }

    private string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays} ngày trước";
        return time.ToString("dd/MM/yyyy");
    }
}

<style>
    .history-page {
        background: #f8f9fa;
        min-height: 100vh;
        padding-bottom: 2rem;
    }

    /* Not Logged In */
    .not-logged-in {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }

    .not-logged-in-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0, 61, 122, 0.1);
        max-width: 450px;
        width: 100%;
        animation: fadeIn 0.6s ease-out;
    }

    .not-logged-in-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
    }

    .not-logged-in-card h2 {
        color: #003d7a;
        margin-bottom: 0.8rem;
        font-size: 1.6rem;
    }

    .not-logged-in-card p {
        color: #666;
        margin-bottom: 1.5rem;
    }

    .btn-login-link {
        display: inline-block;
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
        color: white;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        padding: 2.5rem 2rem;
        color: white;
    }

    .header-content {
        max-width: 900px;
        margin: 0 auto;
        animation: slideDown 0.6s ease-out;
    }

    .header-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .header-content p {
        opacity: 0.9;
        font-size: 1rem;
    }

    /* Summary Bar */
    .summary-bar {
        max-width: 900px;
        margin: -1.5rem auto 2rem;
        padding: 0 1rem;
        position: relative;
        z-index: 10;
    }

    .summary-inner {
        background: white;
        border-radius: 12px;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-around;
        box-shadow: 0 4px 16px rgba(0, 61, 122, 0.1);
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .summary-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: #555;
    }

    .summary-icon {
        font-size: 1.2rem;
    }

    .summary-text strong {
        color: #003d7a;
    }

    /* Timeline Section */
    .timeline-section {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        color: #003d7a;
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #666;
    }

    /* Timeline */
    .timeline {
        position: relative;
        padding: 1rem 0;
    }

    .timeline-item {
        position: relative;
        display: flex;
        gap: 1.5rem;
        padding-bottom: 2rem;
        animation: slideUp 0.5s ease-out;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    .timeline-item:last-child .timeline-line {
        display: none;
    }

    .timeline-line {
        position: absolute;
        left: 22px;
        top: 48px;
        bottom: 0;
        width: 3px;
        background: #e0e0e0;
    }

    .timeline-dot {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.2rem;
        position: relative;
        z-index: 2;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .timeline-dot.color-blue {
        background: linear-gradient(135deg, #003d7a, #0055aa);
        color: white;
    }

    .timeline-dot.color-green {
        background: linear-gradient(135deg, #28a745, #34c759);
        color: white;
    }

    .timeline-dot.color-red {
        background: linear-gradient(135deg, #dc3545, #e74c3c);
        color: white;
    }

    .timeline-dot.color-purple {
        background: linear-gradient(135deg, #6f42c1, #8b5cf6);
        color: white;
    }

    .timeline-dot.color-orange {
        background: linear-gradient(135deg, #fd7e14, #f59e0b);
        color: white;
    }

    .timeline-dot.color-gray {
        background: linear-gradient(135deg, #6c757d, #888);
        color: white;
    }

    .timeline-content {
        flex: 1;
    }

    .timeline-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid #f0f0f0;
    }

    .timeline-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 61, 122, 0.12);
    }

    .timeline-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.2rem;
        border-bottom: 1px solid #f5f5f5;
    }

    .action-badge {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .action-badge.color-blue {
        background: #e8f4fd;
        color: #003d7a;
    }

    .action-badge.color-green {
        background: #d4edda;
        color: #155724;
    }

    .action-badge.color-red {
        background: #f8d7da;
        color: #721c24;
    }

    .action-badge.color-purple {
        background: #e8daf8;
        color: #4a1d96;
    }

    .action-badge.color-orange {
        background: #ffecd2;
        color: #8a4500;
    }

    .action-badge.color-gray {
        background: #e9ecef;
        color: #495057;
    }

    .timeline-time {
        font-size: 0.8rem;
        color: #888;
    }

    .timeline-card-body {
        padding: 1rem 1.2rem;
    }

    .timeline-detail {
        color: #333;
        font-size: 0.95rem;
        line-height: 1.5;
        margin: 0;
    }

    .timeline-detail.muted {
        color: #aaa;
        font-style: italic;
    }

    .timeline-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 1.2rem;
        background: #fafbfc;
        border-top: 1px solid #f5f5f5;
    }

    .timeline-user {
        font-size: 0.8rem;
        color: #666;
    }

    .timeline-relative {
        font-size: 0.75rem;
        color: #999;
        font-style: italic;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .header-content h1 {
            font-size: 1.5rem;
        }

        .summary-inner {
            flex-direction: column;
            align-items: flex-start;
            padding: 1rem;
            gap: 0.8rem;
        }

        .timeline-card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .timeline-card-footer {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.3rem;
        }
    }
</style>
