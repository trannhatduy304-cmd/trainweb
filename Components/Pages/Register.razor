@page "/register"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject NavigationManager NavigationManager

<div class="register-page">
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <div class="register-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="8.5" cy="7" r="4"/>
                        <line x1="20" y1="8" x2="20" y2="14"/>
                        <line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                </div>
                <h1>Tạo Tài Khoản</h1>
                <p>Đăng ký để đặt vé tàu trực tuyến</p>
            </div>

            <div class="register-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                        <span>@errorMessage</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                            <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        <span>@successMessage</span>
                    </div>
                }

                <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                    <div class="form-group">
                        <label for="taikhoan">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#003d7a" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            Tài khoản <span class="required">*</span>
                        </label>
                        <InputText id="taikhoan" @bind-Value="registerModel.TaiKhoan" class="form-input" placeholder="Nhập tài khoản" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="matkhau">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#003d7a" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                                Mật khẩu <span class="required">*</span>
                            </label>
                            <InputText id="matkhau" @bind-Value="registerModel.MatKhau" type="password" class="form-input" placeholder="Nhập mật khẩu" />
                        </div>

                        <div class="form-group">
                            <label for="xacnhanmatkhau">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#003d7a" stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                </svg>
                                Xác nhận mật khẩu <span class="required">*</span>
                            </label>
                            <InputText id="xacnhanmatkhau" @bind-Value="registerModel.XacNhanMatKhau" type="password" class="form-input" placeholder="Nhập lại mật khẩu" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="hoten">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#003d7a" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                            Họ tên <span class="required">*</span>
                        </label>
                        <InputText id="hoten" @bind-Value="registerModel.HoTen" class="form-input" placeholder="Nhập họ và tên" />
                    </div>

                    <div class="form-group">
                        <label for="sodienthoai">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#003d7a" stroke-width="2">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                            Số điện thoại <span class="required">*</span>
                        </label>
                        <InputText id="sodienthoai" @bind-Value="registerModel.SoDienThoai" class="form-input" placeholder="Nhập số điện thoại" />
                    </div>

                    <button type="submit" class="btn-register" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                            <span>Đang xử lý...</span>
                        }
                        else
                        {
                            <span>Đăng Ký</span>
                        }
                    </button>
                </EditForm>

                <div class="register-footer">
                    <p>Đã có tài khoản? <a href="/login">Đăng nhập</a></p>
                </div>
            </div>
        </div>

        <div class="register-decoration">
            <p>Hệ thống đặt vé tàu trực tuyến VNRailway</p>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = false;

    private class RegisterModel
    {
        public string TaiKhoan { get; set; } = "";
        public string MatKhau { get; set; } = "";
        public string XacNhanMatKhau { get; set; } = "";
        public string HoTen { get; set; } = "";
        public string SoDienThoai { get; set; } = "";
    }

    protected override void OnInitialized()
    {
        if (BookingService.DaDangNhap)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleRegister()
    {
        errorMessage = null;
        successMessage = null;

        // Validate required fields
        if (string.IsNullOrWhiteSpace(registerModel.TaiKhoan))
        {
            errorMessage = "Vui lòng nhập tài khoản.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.MatKhau))
        {
            errorMessage = "Vui lòng nhập mật khẩu.";
            return;
        }

        if (registerModel.MatKhau.Length < 6)
        {
            errorMessage = "Mật khẩu phải có ít nhất 6 ký tự.";
            return;
        }

        if (registerModel.MatKhau != registerModel.XacNhanMatKhau)
        {
            errorMessage = "Mật khẩu xác nhận không khớp.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.HoTen))
        {
            errorMessage = "Vui lòng nhập họ tên.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.SoDienThoai))
        {
            errorMessage = "Vui lòng nhập số điện thoại.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        await Task.Delay(500); // Simulate loading

        var (thanhCong, thongBao) = BookingService.DangKy(
            registerModel.TaiKhoan,
            registerModel.MatKhau,
            registerModel.HoTen,
            registerModel.SoDienThoai
        );

        if (thanhCong)
        {
            successMessage = thongBao + " Đang chuyển hướng...";
            isLoading = false;
            StateHasChanged();
            await Task.Delay(1200);
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            errorMessage = thongBao;
            isLoading = false;
        }
    }
}

<style>
    .register-page {
        min-height: 100vh;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .register-container {
        width: 100%;
        max-width: 520px;
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .register-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 61, 122, 0.12);
        overflow: hidden;
    }

    .register-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        text-align: center;
        padding: 32px 32px 24px;
    }

    .register-icon {
        width: 72px;
        height: 72px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        backdrop-filter: blur(10px);
    }

    .register-header h1 {
        margin: 0 0 6px;
        font-size: 26px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .register-header p {
        margin: 0;
        font-size: 14px;
        opacity: 0.85;
        font-weight: 400;
    }

    .register-body {
        padding: 32px;
    }

    .alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 14px;
        margin-bottom: 20px;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .alert-error {
        background: #fef2f2;
        color: #dc3545;
        border: 1px solid #fecaca;
    }

    .alert-success {
        background: #f0fdf4;
        color: #28a745;
        border: 1px solid #bbf7d0;
    }

    .form-group {
        margin-bottom: 18px;
        flex: 1;
    }

    .form-row {
        display: flex;
        gap: 16px;
    }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .required {
        color: #dc3545;
        font-weight: 700;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 15px;
        color: #1a1a2e;
        background: #fafbfc;
        transition: all 0.3s ease;
        outline: none;
        box-sizing: border-box;
    }

    .form-input:focus {
        border-color: #003d7a;
        background: white;
        box-shadow: 0 0 0 4px rgba(0, 61, 122, 0.1);
    }

    .form-input::placeholder {
        color: #adb5bd;
    }

    .btn-register {
        width: 100%;
        padding: 14px 24px;
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 8px;
        letter-spacing: 0.3px;
    }

    .btn-register:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 61, 122, 0.35);
    }

    .btn-register:active:not(:disabled) {
        transform: translateY(0);
    }

    .btn-register:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .register-footer {
        text-align: center;
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
    }

    .register-footer p {
        margin: 0;
        font-size: 14px;
        color: #6c757d;
    }

    .register-footer a {
        color: #003d7a;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .register-footer a:hover {
        color: #005fa3;
        text-decoration: underline;
    }

    .register-decoration {
        text-align: center;
        margin-top: 20px;
    }

    .register-decoration p {
        color: #6c757d;
        font-size: 13px;
        margin: 0;
    }

    @@media (max-width: 540px) {
        .register-body {
            padding: 24px 20px;
        }

        .register-header {
            padding: 28px 20px 24px;
        }

        .register-header h1 {
            font-size: 22px;
        }

        .form-row {
            flex-direction: column;
            gap: 0;
        }
    }
</style>
