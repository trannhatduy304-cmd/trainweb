        background: #90EE90;
        color: #333;
        border-color: #3cb371;
    }

    .seat.available:hover:not(:disabled) {
        background: #7FD97F;
        transform: scale(1.05);
        box-shadow: 0 4px 8px rgba(60, 179, 113, 0.3);
    }

    .seat.selected {
        background: #FFA500;
        color: white;
