@page "/admin"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@using Microsoft.AspNetCore.Components.Forms
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject ProjectTrainWeb.Services.ThanhToanDuyetService DuyetService
@inject NavigationManager NavigationManager

@* Admin Dashboard - Trang Quản Trị Hệ Thống *@

<div class="admin-page">
    @if (!BookingService.LaQuanTri)
    {
        <!-- Access Denied -->
        <div class="access-denied">
            <div class="denied-card">
                <div class="denied-icon">🔒</div>
                <h1>Truy Cập Bị Từ Chối</h1>
                <p>Bạn không có quyền truy cập trang quản trị. Vui lòng đăng nhập bằng tài khoản quản trị viên.</p>
                <button class="btn-back" @onclick='() => NavigationManager.NavigateTo("/")'>
                    ← Quay Về Trang Chủ
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Admin Header -->
        <section class="admin-header">
            <div class="header-container">
                <div class="header-left">
                    <h1>🛡️ Trang Quản Trị</h1>
                    <p>Xin chào, @BookingService.TenHienThi! Quản lý hệ thống ProjectTrain.</p>
                </div>
                <div class="header-right">
                    <span class="admin-badge">👑 Admin</span>
                </div>
            </div>
        </section>

        <!-- Stats Cards -->
        <section class="stats-section">
            <div class="stats-container">
                <div class="stat-card blue">
                    <div class="stat-icon">🎫</div>
                    <div class="stat-info">
                        <span class="stat-number">@thongKe.tongVe</span>
                        <span class="stat-label">Tổng Vé</span>
                    </div>
                </div>
                <div class="stat-card green">
                    <div class="stat-icon">👥</div>
                    <div class="stat-info">
                        <span class="stat-number">@thongKe.tongHanhKhach</span>
                        <span class="stat-label">Tổng Hành Khách</span>
                    </div>
                </div>
                <div class="stat-card orange">
                    <div class="stat-icon">💰</div>
                    <div class="stat-info">
                        <span class="stat-number">@thongKe.tongDoanhThu.ToString("N0")</span>
                        <span class="stat-label">Doanh Thu (VND)</span>
                    </div>
                </div>
                <div class="stat-card purple">
                    <div class="stat-icon">🚂</div>
                    <div class="stat-info">
                        <span class="stat-number">@thongKe.tongChuyenTau</span>
                        <span class="stat-label">Tổng Chuyến Tàu</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tab Navigation -->
        <section class="tab-section">
            <div class="tab-container">
                <div class="tab-nav">
                    <button class="tab-btn @(activeTab == "trains" ? "active" : "")" @onclick='() => activeTab = "trains"'>
                        🚂 Chuyến Tàu
                    </button>
                    <button class="tab-btn @(activeTab == "users" ? "active" : "")" @onclick='() => activeTab = "users"'>
                        👥 Hành Khách
                    </button>
                    <button class="tab-btn @(activeTab == "transactions" ? "active" : "")" @onclick='() => activeTab = "transactions"'>
                        💳 Giao Dịch
                    </button>
                    <button class="tab-btn @(activeTab == "logs" ? "active" : "")" @onclick='() => activeTab = "logs"'>
                        📋 Lịch Sử
                    </button>
                    <button class="tab-btn @(activeTab == "approval" ? "active" : "")" @onclick='() => activeTab = "approval"'>
                        💳 Duyệt Thanh Toán
                        @{ int soChoDuyet = DuyetService.DemYeuCauChoDuyet(); }
                        @if (soChoDuyet > 0)
                        {
                            <span class="tab-badge">@soChoDuyet</span>
                        }
                    </button>
                    <button class="tab-btn @(activeTab == "payment-config" ? "active" : "")" @onclick='() => activeTab = "payment-config"'>
                        ⚙️ Cấu Hình TT
                    </button>
                    <button class="tab-btn @(activeTab == "manage-trains" ? "active" : "")" @onclick='() => activeTab = "manage-trains"'>
                        🚂 Quản Lý Tàu
                    </button>
                    <button class="tab-btn @(activeTab == "content" ? "active" : "")" @onclick='() => activeTab = "content"'>
                        📝 Nội Dung
                    </button>
                    <button class="tab-btn @(activeTab == "accounts" ? "active" : "")" @onclick='() => activeTab = "accounts"'>
                        👥 Tài Khoản
                    </button>
                </div>

                <!-- Trains Table -->
                @if (activeTab == "trains")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Danh Sách Chuyến Tàu</h2>
                            <span class="record-count">@BookingService.DanhSachChuyenTau.Count chuyến</span>
                        </div>
                        <div class="table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Mã Chuyến</th>
                                        <th>Ga Đi</th>
                                        <th>Ga Đến</th>
                                        <th>Khởi Hành</th>
                                        <th>Đến Dự Kiến</th>
                                        <th>Số Toa</th>
                                        <th>Ghế Trống</th>
                                        <th>Trạng Thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ct in BookingService.DanhSachChuyenTau)
                                    {
                                        int tongGhe = ct.DanhSachToa.Sum(t => t.DanhSachGhe.Count);
                                        int gheTrong = ct.DanhSachToa.Sum(t => t.DemGheTrong());
                                        <tr>
                                            <td><span class="code-text">CT-@ct.MaChuyen</span></td>
                                            <td>@(ct.GaDi?.TenGa ?? "N/A")</td>
                                            <td>@(ct.GaDen?.TenGa ?? "N/A")</td>
                                            <td>@ct.ThoiGianKhoiHanh.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@ct.ThoiGianDenDu.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="center">@ct.DanhSachToa.Count</td>
                                            <td>
                                                <span class="seat-badge @(gheTrong > 0 ? "available" : "full")">
                                                    @gheTrong / @tongGhe
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge @(ct.ConHopLe() ? "active" : "expired")">
                                                    @(ct.ConHopLe() ? "Hoạt Động" : "Hết Hạn")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Users Table -->
                @if (activeTab == "users")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Danh Sách Hành Khách</h2>
                            <span class="record-count">@BookingService.DanhSachHanhKhach.Count hành khách</span>
                        </div>
                        <div class="table-responsive">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Mã ND</th>
                                        <th>Họ Tên</th>
                                        <th>Tài Khoản</th>
                                        <th>Số Điện Thoại</th>
                                        <th>Số Vé</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hk in BookingService.DanhSachHanhKhach)
                                    {
                                        int soVe = BookingService.DanhSachVe.Count(v => v.HanhKhach?.MaNguoiDung == hk.MaNguoiDung);
                                        <tr>
                                            <td><span class="code-text">HK-@hk.MaNguoiDung</span></td>
                                            <td><strong>@hk.HoTen</strong></td>
                                            <td>@hk.TaiKhoan</td>
                                            <td>@hk.SoDienThoai</td>
                                            <td class="center">@soVe</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Transactions Table -->
                @if (activeTab == "transactions")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Giao Dịch Gần Đây</h2>
                            <span class="record-count">@BookingService.DanhSachGiaoDich.Count giao dịch</span>
                        </div>
                        <div class="table-responsive">
                            @if (BookingService.DanhSachGiaoDich.Count == 0)
                            {
                                <div class="empty-state">
                                    <span class="empty-icon">💳</span>
                                    <p>Chưa có giao dịch nào trong hệ thống.</p>
                                </div>
                            }
                            else
                            {
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Mã GD</th>
                                            <th>Số Tiền</th>
                                            <th>Phương Thức</th>
                                            <th>Loại GD</th>
                                            <th>Trạng Thái</th>
                                            <th>Ngày Thực Hiện</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var gd in BookingService.DanhSachGiaoDich.OrderByDescending(g => g.NgayThucHien))
                                        {
                                            <tr>
                                                <td><span class="code-text">@gd.MaGiaoDich.Substring(0, Math.Min(8, gd.MaGiaoDich.Length))...</span></td>
                                                <td class="money @(gd.LoaiGiaoDich == "Hoan Tien" ? "refund" : "")">
                                                    @(gd.LoaiGiaoDich == "Hoan Tien" ? "+" : "-")@gd.SoTien.ToString("N0") VND
                                                </td>
                                                <td>@gd.PhuongThuc</td>
                                                <td>
                                                    <span class="type-badge @(gd.LoaiGiaoDich == "Hoan Tien" ? "refund" : "payment")">
                                                        @gd.LoaiGiaoDich
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="status-badge @(gd.TrangThai == "Thanh Cong" ? "active" : "expired")">
                                                        @gd.TrangThai
                                                    </span>
                                                </td>
                                                <td>@gd.NgayThucHien.ToString("dd/MM/yyyy HH:mm")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }

                <!-- System Logs -->
                @if (activeTab == "logs")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Lịch Sử Hệ Thống</h2>
                            <span class="record-count">@BookingService.DanhSachLichSu.Count bản ghi</span>
                        </div>
                        <div class="table-responsive">
                            @if (BookingService.DanhSachLichSu.Count == 0)
                            {
                                <div class="empty-state">
                                    <span class="empty-icon">📋</span>
                                    <p>Chưa có lịch sử hoạt động nào.</p>
                                </div>
                            }
                            else
                            {
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Thời Gian</th>
                                            <th>Hành Động</th>
                                            <th>Người Thực Hiện</th>
                                            <th>Chi Tiết</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ls in BookingService.DanhSachLichSu.OrderByDescending(l => l.ThoiGian).Take(20))
                                        {
                                            <tr>
                                                <td class="time-cell">@ls.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                                <td>
                                                    <span class="action-badge">@ls.HanhDong</span>
                                                </td>
                                                <td><strong>@ls.NguoiThucHien</strong></td>
                                                <td class="detail-cell">@ls.ChiTiet</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }

                <!-- Duyệt Thanh Toán -->
                @if (activeTab == "approval")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Duyệt Yêu Cầu Thanh Toán</h2>
                            <span class="record-count">@DuyetService.LayTatCaYeuCau().Count yêu cầu</span>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert-message @(isSuccess ? "success" : "error")">
                                @message
                            </div>
                        }

                        <div class="table-responsive">
                            @{ var danhSachYeuCau = DuyetService.LayTatCaYeuCau(); }
                            @if (danhSachYeuCau.Count == 0)
                            {
                                <div class="empty-state">
                                    <span class="empty-icon">💳</span>
                                    <p>Chưa có yêu cầu thanh toán nào.</p>
                                </div>
                            }
                            else
                            {
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Mã Yêu Cầu</th>
                                            <th>Người Đặt</th>
                                            <th>Mã Vé</th>
                                            <th>Số Tiền</th>
                                            <th>Thời Gian Gửi</th>
                                            <th>Trạng Thái</th>
                                            <th>Thao Tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var yc in danhSachYeuCau)
                                        {
                                            <tr>
                                                <td><span class="code-text">@yc.MaYeuCau.Substring(0, Math.Min(8, yc.MaYeuCau.Length))...</span></td>
                                                <td><strong>@yc.NguoiDat?.HoTen</strong></td>
                                                <td><span class="code-text">@(yc.Ve?.MaVe.Substring(0, Math.Min(8, yc.Ve.MaVe.Length)) ?? "N/A")...</span></td>
                                                <td class="money">@yc.SoTienThanhToan.ToString("N0") VND</td>
                                                <td>@yc.ThoiGianGui.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>
                                                    @if (yc.TrangThai == "Chờ Duyệt")
                                                    {
                                                        <span class="status-badge pending">🟡 Chờ Duyệt</span>
                                                    }
                                                    else if (yc.TrangThai == "Đã Duyệt")
                                                    {
                                                        <span class="status-badge active">🟢 Đã Duyệt</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge rejected">🔴 Từ Chối</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (yc.TrangThai == "Chờ Duyệt")
                                                    {
                                                        <div class="action-buttons">
                                                            <button class="btn-approve" @onclick="() => XuLyDuyet(yc.MaYeuCau)">
                                                                ✅ Duyệt
                                                            </button>
                                                            <button class="btn-reject" @onclick="() => XuLyTuChoi(yc.MaYeuCau)">
                                                                ❌ Từ Chối
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Đã xử lý</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                }

                <!-- Cấu Hình Thanh Toán -->
                @if (activeTab == "payment-config")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Cấu Hình Thanh Toán</h2>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert-message @(isSuccess ? "success" : "error")">
                                @message
                            </div>
                        }

                        <div class="form-container">
                            <div class="form-group">
                                <label>Số Tài Khoản</label>
                                <input type="text" class="form-input" @bind="localCauHinh.SoTaiKhoan" />
                            </div>
                            <div class="form-group">
                                <label>Tên Ngân Hàng</label>
                                <input type="text" class="form-input" @bind="localCauHinh.TenNganHang" />
                            </div>
                            <div class="form-group">
                                <label>Tên Chủ Tài Khoản</label>
                                <input type="text" class="form-input" @bind="localCauHinh.TenChuTaiKhoan" />
                            </div>
                            <div class="form-group">
                                <label>Chi Nhánh</label>
                                <input type="text" class="form-input" @bind="localCauHinh.ChiNhanh" />
                            </div>
                            <div class="form-group">
                                <label>Nội Dung Chuyển Khoản Mẫu</label>
                                <input type="text" class="form-input" @bind="localCauHinh.NoiDungMau" />
                            </div>
                            <div class="form-group">
                                <label>Upload Hình QR</label>
                                <InputFile OnChange="HandleQRUpload" class="form-input-file" />
                            </div>

                            @if (!string.IsNullOrEmpty(localCauHinh.HinhQR))
                            {
                                <div class="qr-preview">
                                    <label>Xem Trước QR:</label>
                                    <img src="@localCauHinh.HinhQR" alt="QR Preview" class="qr-image" />
                                </div>
                            }

                            <div class="form-actions">
                                <button class="btn-save" @onclick="LuuCauHinhThanhToan">
                                    💾 Lưu Cấu Hình
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- Quản Lý Chuyến Tàu -->
                @if (activeTab == "manage-trains")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Quản Lý Chuyến Tàu</h2>
                            <span class="record-count">@BookingService.DanhSachChuyenTau.Count chuyến</span>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert-message @(isSuccess ? "success" : "error")">
                                @message
                            </div>
                        }

                        <!-- Form thêm chuyến tàu -->
                        <div class="form-container">
                            <h3 class="form-title">➕ Thêm Chuyến Tàu Mới</h3>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Ga Đi</label>
                                    <select class="form-input" @bind="newGaDi">
                                        <option value="0">-- Chọn Ga Đi --</option>
                                        @foreach (var ga in BookingService.DanhSachGa)
                                        {
                                            <option value="@ga.MaGa">@ga.TenGa (@ga.ThanhPho)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Ga Đến</label>
                                    <select class="form-input" @bind="newGaDen">
                                        <option value="0">-- Chọn Ga Đến --</option>
                                        @foreach (var ga in BookingService.DanhSachGa)
                                        {
                                            <option value="@ga.MaGa">@ga.TenGa (@ga.ThanhPho)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Giờ Khởi Hành</label>
                                    <input type="datetime-local" class="form-input" @bind="newKhoiHanh" />
                                </div>
                                <div class="form-group">
                                    <label>Giờ Đến Dự Kiến</label>
                                    <input type="datetime-local" class="form-input" @bind="newDenDu" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Số Toa (mỗi toa 40 ghế, giá cơ bản 300.000 VND)</label>
                                <input type="number" class="form-input" @bind="newSoToa" min="1" max="20" />
                            </div>
                            <div class="form-actions">
                                <button class="btn-save" @onclick="ThemChuyenTau">
                                    ➕ Thêm Chuyến Tàu
                                </button>
                            </div>
                        </div>

                        <!-- Bảng danh sách chuyến tàu -->
                        <div class="table-responsive" style="margin-top: 1.5rem;">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Mã Chuyến</th>
                                        <th>Ga Đi</th>
                                        <th>Ga Đến</th>
                                        <th>Khởi Hành</th>
                                        <th>Đến Dự Kiến</th>
                                        <th>Số Toa</th>
                                        <th>Trạng Thái</th>
                                        <th>Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ct in BookingService.DanhSachChuyenTau)
                                    {
                                        <tr>
                                            <td><span class="code-text">CT-@ct.MaChuyen</span></td>
                                            <td>@(ct.GaDi?.TenGa ?? "N/A")</td>
                                            <td>@(ct.GaDen?.TenGa ?? "N/A")</td>
                                            <td>@ct.ThoiGianKhoiHanh.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@ct.ThoiGianDenDu.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="center">@ct.DanhSachToa.Count</td>
                                            <td>
                                                <span class="status-badge @(ct.ConHopLe() ? "active" : "expired")">
                                                    @(ct.ConHopLe() ? "Hoạt Động" : "Hết Hạn")
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn-delete" @onclick="() => XoaChuyenTau(ct)">
                                                    🗑️ Xóa
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Quản Lý Nội Dung -->
                @if (activeTab == "content")
                {
                    <div class="tab-content">
                        <div class="table-header">
                            <h2>Quản Lý Nội Dung Hệ Thống</h2>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert-message @(isSuccess ? "success" : "error")">
                                @message
                            </div>
                        }

                        <div class="form-container">
                            <div class="form-group">
                                <label>📢 Thông Báo Chung</label>
                                <textarea class="form-textarea" rows="3" @bind="localCauHinhHT.ThongBaoChung"></textarea>
                            </div>
                            <div class="form-group">
                                <label>🔄 Chính Sách Hoàn Vé</label>
                                <textarea class="form-textarea" rows="3" @bind="localCauHinhHT.ChinhSachHoanVe"></textarea>
                            </div>
                            <div class="form-group">
                                <label>🔒 Chính Sách Bảo Mật</label>
                                <textarea class="form-textarea" rows="3" @bind="localCauHinhHT.ChinhSachBaoMat"></textarea>
                            </div>
                            <div class="form-group">
                                <label>📜 Điều Khoản Sử Dụng</label>
                                <textarea class="form-textarea" rows="3" @bind="localCauHinhHT.DieuKhoanSuDung"></textarea>
                            </div>
                            <div class="form-group">
                                <label>📞 Điện Thoại</label>
                                <input type="text" class="form-input" @bind="localCauHinhHT.DienThoaiLienHe" />
                            </div>
                            <div class="form-group">
