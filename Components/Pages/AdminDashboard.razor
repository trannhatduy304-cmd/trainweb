</div>

@code {
    private string activeTab = "trains";
    private (int tongVe, int tongHanhKhach, double tongDoanhThu, int tongChuyenTau) thongKe;

    // Feedback message
    private string message = "";
    private bool isSuccess = false;

    // Form thêm chuyến tàu
    private int newGaDi = 0;
    private int newGaDen = 0;
    private DateTime newKhoiHanh = DateTime.Now.AddHours(2);
    private DateTime newDenDu = DateTime.Now.AddHours(10);
    private int newSoToa = 3;

    // Cấu hình thanh toán
    private CauHinhThanhToan localCauHinh = new();

    // Cấu hình hệ thống
    private CauHinhHeThong localCauHinhHT = new();

    protected override void OnInitialized()
    {
        if (BookingService.LaQuanTri)
        {
            thongKe = BookingService.LayThongKe();
            // Load cấu hình hiện tại
            var cauHinhHienTai = DuyetService.LayCauHinhThanhToan();
            localCauHinh = new CauHinhThanhToan
            {
                SoTaiKhoan = cauHinhHienTai.SoTaiKhoan,
                TenNganHang = cauHinhHienTai.TenNganHang,
                TenChuTaiKhoan = cauHinhHienTai.TenChuTaiKhoan,
                ChiNhanh = cauHinhHienTai.ChiNhanh,
                HinhQR = cauHinhHienTai.HinhQR,
                NoiDungMau = cauHinhHienTai.NoiDungMau
            };

            var cauHinhHTHienTai = DuyetService.LayCauHinhHeThong();
            localCauHinhHT = new CauHinhHeThong
            {
                ThongBaoChung = cauHinhHTHienTai.ThongBaoChung,
                ChinhSachHoanVe = cauHinhHTHienTai.ChinhSachHoanVe,
                ChinhSachBaoMat = cauHinhHTHienTai.ChinhSachBaoMat,
                DieuKhoanSuDung = cauHinhHTHienTai.DieuKhoanSuDung,
                ThongTinLienHe = cauHinhHTHienTai.ThongTinLienHe
            };
        }
    }

    // === Duyệt Thanh Toán ===
    private void XuLyDuyet(string maYeuCau)
    {
        var result = DuyetService.DuyetThanhToan(maYeuCau);
        message = result.thongBao;
        isSuccess = result.thanhCong;
        thongKe = BookingService.LayThongKe();
        StateHasChanged();
    }

    private void XuLyTuChoi(string maYeuCau)
    {
        var result = DuyetService.TuChoiThanhToan(maYeuCau, "Admin từ chối yêu cầu thanh toán.");
        message = result.thongBao;
        isSuccess = result.thanhCong;
        StateHasChanged();
    }

    // === Cấu Hình Thanh Toán ===
    private async Task HandleQRUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            localCauHinh.HinhQR = $"data:{file.ContentType};base64,{base64}";
            StateHasChanged();
        }
    }

    private void LuuCauHinhThanhToan()
    {
        DuyetService.LuuCauHinhThanhToan(localCauHinh);
        message = "Đã lưu cấu hình thanh toán thành công!";
        isSuccess = true;
        StateHasChanged();
    }

    // === Quản Lý Chuyến Tàu ===
    private void ThemChuyenTau()
    {
        if (newGaDi == 0 || newGaDen == 0)
        {
            message = "Vui lòng chọn ga đi và ga đến!";
            isSuccess = false;
            return;
        }
        if (newGaDi == newGaDen)
        {
            message = "Ga đi và ga đến không được trùng nhau!";
            isSuccess = false;
            return;
        }
        if (newKhoiHanh >= newDenDu)
        {
            message = "Giờ khởi hành phải trước giờ đến!";
            isSuccess = false;
            return;
        }
        if (newSoToa < 1)
        {
            message = "Số toa phải lớn hơn 0!";
            isSuccess = false;
            return;
        }

        var gaDi = BookingService.DanhSachGa.FirstOrDefault(g => g.MaGa == newGaDi);
        var gaDen = BookingService.DanhSachGa.FirstOrDefault(g => g.MaGa == newGaDen);
        int maChuyen = BookingService.DanhSachChuyenTau.Count > 0
            ? BookingService.DanhSachChuyenTau.Max(ct => ct.MaChuyen) + 1
            : 1;

        var chuyenMoi = new ChuyenTau(maChuyen, gaDi, gaDen, newKhoiHanh, newDenDu);

        for (int i = 1; i <= newSoToa; i++)
        {
            var toa = new ToaTau($"{maChuyen}-T{i}", "Ngồi Mềm", 40, 300000);
            chuyenMoi.ThemToa(toa);
        }

        BookingService.DanhSachChuyenTau.Add(chuyenMoi);
        thongKe = BookingService.LayThongKe();
        message = $"Đã thêm chuyến tàu CT-{maChuyen} thành công!";
        isSuccess = true;

        // Reset form
        newGaDi = 0;
        newGaDen = 0;
        newKhoiHanh = DateTime.Now.AddHours(2);
        newDenDu = DateTime.Now.AddHours(10);
        newSoToa = 3;
        StateHasChanged();
    }

    private void XoaChuyenTau(ChuyenTau ct)
    {
        BookingService.DanhSachChuyenTau.Remove(ct);
        thongKe = BookingService.LayThongKe();
        message = $"Đã xóa chuyến tàu CT-{ct.MaChuyen} thành công!";
        isSuccess = true;
        StateHasChanged();
    }

    // === Cấu Hình Hệ Thống ===
    private void LuuCauHinhHeThong()
    {
        DuyetService.LuuCauHinhHeThong(localCauHinhHT);
        message = "Đã lưu cấu hình hệ thống thành công!";
        isSuccess = true;
        StateHasChanged();
    }

    // === Quản Lý Tài Khoản ===
    private string accountMessage = "";
    private bool accountSuccess = false;

    private void XoaTaiKhoanHK(string taiKhoan)
    {
        var (ok, msg) = BookingService.XoaTaiKhoan(taiKhoan);
        accountMessage = msg;
        accountSuccess = ok;
        if (ok) thongKe = BookingService.LayThongKe();
        StateHasChanged();
    }

    private void LuuTaiKhoan()
    {
        BookingService.SaveAccounts();
        accountMessage = "Đã lưu tất cả tài khoản vào file thành công!";
        accountSuccess = true;
        StateHasChanged();
    }
}

