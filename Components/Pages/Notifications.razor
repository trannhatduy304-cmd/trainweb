@page "/notifications"
@rendermode InteractiveServer
@using ProjectTrainWeb.Models
@inject ProjectTrainWeb.Services.TrainBookingService BookingService
@inject NavigationManager NavigationManager

<div class="notifications-page">
    @if (!BookingService.DaDangNhap)
    {
        <!-- Not Logged In -->
        <div class="not-logged-in">
            <div class="not-logged-in-card">
                <div class="not-logged-in-icon">🔔</div>
                <h2>Chưa Đăng Nhập</h2>
                <p>Bạn cần đăng nhập để xem thông báo.</p>
                <a href="/login" class="btn-login-link">Đăng Nhập Ngay</a>
            </div>
        </div>
    }
    else
    {
        var notifications = BookingService.LayThongBaoCuaToi();
        var unreadCount = notifications.Count(t => t.TrangThai == "Chua Gui");
        var sentCount = notifications.Count(t => t.TrangThai == "Da Gui");

        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <div class="header-title-row">
                    <h1>🔔 Thông Báo</h1>
                    @if (unreadCount > 0)
                    {
                        <span class="unread-badge">@unreadCount mới</span>
                    }
                </div>
                <p>Xem tất cả thông báo và cập nhật từ hệ thống</p>
            </div>
        </div>

        <!-- Stats Bar -->
        <div class="stats-bar">
            <div class="stats-bar-inner">
                <div class="mini-stat">
                    <span class="mini-stat-icon">📬</span>
                    <span class="mini-stat-value">@notifications.Count</span>
                    <span class="mini-stat-label">Tổng Thông Báo</span>
                </div>
                <div class="mini-stat">
                    <span class="mini-stat-icon">🆕</span>
                    <span class="mini-stat-value unread">@unreadCount</span>
                    <span class="mini-stat-label">Chưa Gửi</span>
                </div>
                <div class="mini-stat">
                    <span class="mini-stat-icon">✅</span>
                    <span class="mini-stat-value sent">@sentCount</span>
                    <span class="mini-stat-label">Đã Gửi</span>
                </div>
            </div>
        </div>

        <!-- Message -->
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="message-section">
                <div class="alert alert-success">
                    @message
                </div>
            </div>
        }

        <!-- Notifications List -->
        <div class="notifications-section">
            @if (notifications.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">🔕</div>
                    <h3>Không có thông báo</h3>
                    <p>Bạn chưa có thông báo nào. Thông báo sẽ xuất hiện khi bạn đặt vé hoặc có cập nhật từ hệ thống.</p>
                </div>
            }
            else
            {
                <div class="notifications-list">
                    @foreach (var tb in notifications.OrderByDescending(t => t.ThoiGianGui))
                    {
                        <div class="notification-card @(tb.TrangThai == "Chua Gui" ? "unread" : "")">
                            <!-- Channel Icon -->
                            <div class="notification-channel">
                                @if (tb.KenhGui == "Email")
                                {
                                    <div class="channel-icon email">
                                        <span>📧</span>
                                    </div>
                                }
                                else if (tb.KenhGui == "SMS")
                                {
                                    <div class="channel-icon sms">
                                        <span>💬</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="channel-icon other">
                                        <span>🔔</span>
                                    </div>
                                }
                            </div>

                            <!-- Notification Content -->
                            <div class="notification-body">
                                <div class="notification-header">
                                    <div class="notification-meta">
                                        <span class="channel-label">@tb.KenhGui</span>
                                        <span class="notification-status @(GetStatusClass(tb.TrangThai))">
                                            @GetStatusIcon(tb.TrangThai) @tb.TrangThai
                                        </span>
                                    </div>
                                    <span class="notification-time">@tb.ThoiGianGui.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>

                                <p class="notification-content">@tb.NoiDung</p>

                                <div class="notification-footer">
                                    <span class="notification-relative">@GetRelativeTime(tb.ThoiGianGui)</span>

                                    @if (tb.TrangThai == "Chua Gui")
                                    {
                                        <button class="btn-mark-sent" @onclick="() => MarkAsSent(tb)">
                                            ✅ Đánh Dấu Đã Gửi
                                        </button>
                                    }
                                    else if (tb.TrangThai == "That Bai")
                                    {
                                        <span class="failed-label">⚠️ Gửi thất bại</span>
                                    }
                                </div>
                            </div>

                            <!-- Unread Indicator -->
                            @if (tb.TrangThai == "Chua Gui")
                            {
                                <div class="unread-indicator"></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private string message = "";

    private void MarkAsSent(ThongBao tb)
    {
        tb.DanhDauDaGui();
        message = "Đã đánh dấu thông báo là đã gửi!";
    }

    private string GetStatusClass(string trangThai)
    {
        return trangThai switch
        {
            "Da Gui" => "status-sent",
            "Chua Gui" => "status-pending",
            "That Bai" => "status-failed",
            _ => "status-pending"
        };
    }

    private string GetStatusIcon(string trangThai)
    {
        return trangThai switch
        {
            "Da Gui" => "✅",
            "Chua Gui" => "⏳",
            "That Bai" => "❌",
            _ => "⏳"
        };
    }

    private string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays} ngày trước";
        return time.ToString("dd/MM/yyyy");
    }
}

<style>
    .notifications-page {
        background: #f8f9fa;
        min-height: 100vh;
        padding-bottom: 2rem;
    }

    /* Not Logged In */
    .not-logged-in {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 2rem;
    }

    .not-logged-in-card {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0, 61, 122, 0.1);
        max-width: 450px;
        width: 100%;
        animation: fadeIn 0.6s ease-out;
    }

    .not-logged-in-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
    }

    .not-logged-in-card h2 {
        color: #003d7a;
        margin-bottom: 0.8rem;
        font-size: 1.6rem;
    }

    .not-logged-in-card p {
        color: #666;
        margin-bottom: 1.5rem;
    }

    .btn-login-link {
        display: inline-block;
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
        color: white;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        padding: 2.5rem 2rem;
        color: white;
    }

    .header-content {
        max-width: 900px;
        margin: 0 auto;
        animation: slideDown 0.6s ease-out;
    }

    .header-title-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.3rem;
    }

    .header-title-row h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
    }

    .unread-badge {
        background: #ff4444;
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .header-content p {
        opacity: 0.9;
        font-size: 1rem;
        margin: 0;
    }

    /* Stats Bar */
    .stats-bar {
        max-width: 900px;
        margin: -1.5rem auto 2rem;
        padding: 0 1rem;
        position: relative;
        z-index: 10;
    }

    .stats-bar-inner {
        background: white;
        border-radius: 12px;
        padding: 1.2rem 2rem;
        display: flex;
        justify-content: space-around;
        box-shadow: 0 4px 16px rgba(0, 61, 122, 0.1);
    }

    .mini-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
    }

    .mini-stat-icon {
        font-size: 1.5rem;
    }

    .mini-stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #003d7a;
    }

    .mini-stat-value.unread {
        color: #fd7e14;
    }

    .mini-stat-value.sent {
        color: #28a745;
    }

    .mini-stat-label {
        font-size: 0.75rem;
        color: #888;
    }

    /* Message */
    .message-section {
        max-width: 900px;
        margin: 0 auto 1rem;
        padding: 0 1rem;
    }

    .alert {
        padding: 0.8rem 1.2rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        color: #003d7a;
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #666;
        max-width: 400px;
        margin: 0 auto;
    }

    /* Notifications Section */
    .notifications-section {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .notifications-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* Notification Card */
    .notification-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.08);
        display: flex;
        gap: 1.2rem;
        transition: all 0.3s ease;
        animation: slideUp 0.5s ease-out;
        position: relative;
        border: 1px solid #f0f0f0;
    }

    .notification-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 61, 122, 0.12);
    }

    .notification-card.unread {
        border-left: 4px solid #003d7a;
        background: #fafcff;
    }

    /* Channel Icon */
    .notification-channel {
        flex-shrink: 0;
    }

    .channel-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .channel-icon.email {
        background: linear-gradient(135deg, #e8f4fd, #d0e8f7);
    }

    .channel-icon.sms {
        background: linear-gradient(135deg, #d4edda, #c3e6cb);
    }

    .channel-icon.other {
        background: linear-gradient(135deg, #ffecd2, #ffe0b2);
    }

    /* Notification Body */
    .notification-body {
        flex: 1;
        min-width: 0;
    }

    .notification-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.6rem;
    }

    .notification-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .channel-label {
        font-size: 0.8rem;
        color: #003d7a;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .notification-status {
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .notification-status.status-sent {
        background: #d4edda;
        color: #155724;
    }

    .notification-status.status-pending {
        background: #fff3cd;
        color: #856404;
    }

    .notification-status.status-failed {
        background: #f8d7da;
        color: #721c24;
    }

    .notification-time {
        font-size: 0.8rem;
        color: #999;
    }

    .notification-content {
        color: #333;
        font-size: 0.95rem;
        line-height: 1.6;
        margin: 0 0 0.8rem 0;
    }

    .notification-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 0.8rem;
        border-top: 1px solid #f5f5f5;
    }

    .notification-relative {
        font-size: 0.75rem;
        color: #aaa;
        font-style: italic;
    }

    .btn-mark-sent {
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.8rem;
    }

    .btn-mark-sent:hover {
        background: linear-gradient(135deg, #002d5a 0%, #003d7a 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 61, 122, 0.3);
    }

    .failed-label {
        font-size: 0.8rem;
        color: #dc3545;
        font-weight: 600;
    }

    /* Unread Indicator */
    .unread-indicator {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #003d7a;
        animation: blink 2s infinite;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .header-title-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .header-title-row h1 {
            font-size: 1.5rem;
        }

        .stats-bar-inner {
            padding: 1rem;
        }

        .notification-card {
            flex-direction: column;
        }

        .notification-channel {
            display: flex;
        }

        .notification-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.3rem;
        }

        .notification-footer {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.6rem;
        }
    }
</style>
