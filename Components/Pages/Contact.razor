@page "/contact"
@inject ProjectTrainWeb.Services.ThanhToanDuyetService DuyetService
@* Contact Page - Trang Liên Hệ *@

<PageTitle>Liên Hệ - ProjectTrain</PageTitle>

@{
    var cauHinh = DuyetService.LayCauHinhHeThong();
}

<div class="contact-page">
    <!-- Header -->
    <section class="contact-header">
        <div class="header-content">
            <h1>Liên Hệ Với Chúng Tôi</h1>
            <p>Chúng tôi luôn sẵn sàng hỗ trợ bạn 24/7</p>
        </div>
    </section>

    <!-- Main Content -->
    <div class="contact-main">
        <!-- Contact Info Cards -->
        <div class="info-cards">
            <div class="info-card">
                <div class="info-icon">📞</div>
                <h3>Điện Thoại</h3>
                <p class="info-value">@cauHinh.DienThoaiLienHe</p>
                <p class="info-desc">Hỗ trợ 24/7, mọi ngày</p>
            </div>
            <div class="info-card">
                <div class="info-icon">📧</div>
                <h3>Email</h3>
                <p class="info-value">@cauHinh.EmailLienHe</p>
                <p class="info-desc">Phản hồi trong 24 giờ</p>
            </div>
            <div class="info-card">
                <div class="info-icon">📍</div>
                <h3>Địa Chỉ</h3>
                <p class="info-value">@cauHinh.DiaChiLienHe</p>
                <p class="info-desc">Văn phòng chính</p>
            </div>
            <div class="info-card">
                <div class="info-icon">🕐</div>
                <h3>Giờ Làm Việc</h3>
                <p class="info-value">08:00 - 22:00</p>
                <p class="info-desc">Thứ 2 - Chủ Nhật</p>
            </div>
        </div>

        <!-- Contact Form & FAQ -->
        <div class="contact-content">
            <!-- Contact Form -->
            <div class="contact-form-card">
                <h2>Gửi Liên Hệ</h2>
                <p class="form-desc">Điền đầy đủ thông tin, chúng tôi sẽ phản hồi sớm nhất có thể.</p>

                <div class="form-group">
                    <label>Họ và Tên *</label>
                    <input type="text" class="form-input" placeholder="Nhập họ và tên" />
                </div>
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" class="form-input" placeholder="Nhập địa chỉ email" />
                </div>
                <div class="form-group">
                    <label>Chủ Đề</label>
                    <select class="form-input">
                        <option value="">Chọn chủ đề</option>
                        <option value="booking">Đặt vé / Hủy vé</option>
                        <option value="payment">Thanh toán / Hoàn tiền</option>
                        <option value="account">Tài khoản</option>
                        <option value="complaint">Khiếu nại</option>
                        <option value="other">Khác</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Nội Dung *</label>
                    <textarea class="form-input textarea" rows="5" placeholder="Nhập nội dung liên hệ..."></textarea>
                </div>
                <button class="btn-submit">
                    📨 Gửi Liên Hệ
                </button>
            </div>

            <!-- FAQ Section -->
            <div class="faq-card">
                <h2>Câu Hỏi Thường Gặp</h2>

                <div class="faq-item">
                    <div class="faq-question">
                        <span class="faq-icon">❓</span>
                        <span>Làm sao để đặt vé tàu?</span>
                    </div>
                    <div class="faq-answer">
                        Bạn cần đăng ký tài khoản, chọn chuyến tàu phù hợp, chọn ghế ngồi và tiến hành thanh toán. Vé điện tử sẽ được gửi qua email sau khi thanh toán thành công.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        <span class="faq-icon">❓</span>
                        <span>Tôi có thể hủy vé không?</span>
                    </div>
                    <div class="faq-answer">
                        Có, bạn có thể hủy vé bất cứ lúc nào trước giờ khởi hành 24 giờ. Tiền sẽ được hoàn vào tài khoản ví hệ thống của bạn.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        <span class="faq-icon">❓</span>
                        <span>Các phương thức thanh toán nào được hỗ trợ?</span>
                    </div>
                    <div class="faq-answer">
                        Chúng tôi hỗ trợ: Ví Hệ Thống (số dư tài khoản), VNPay và Momo. Bạn có thể chọn phương thức phù hợp khi thanh toán.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        <span class="faq-icon">❓</span>
                        <span>Vé VIP khác gì so với Vé Thường?</span>
                    </div>
                    <div class="faq-answer">
                        Vé VIP có hệ số 1.3x giá cơ bản, bao gồm các dịch vụ cao cấp hơn: ghế rộng hơn, phòng chờ VIP, bữa ăn miễn phí trên tàu và ưu tiên lên tàu.
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        <span class="faq-icon">❓</span>
                        <span>Làm sao để sử dụng mã khuyến mãi?</span>
                    </div>
                    <div class="faq-answer">
                        Tại trang thanh toán, bạn nhập mã khuyến mãi vào ô "Mã Khuyến Mãi" và nhấn "Áp Dụng". Hệ thống sẽ tự động tính số tiền giảm giá cho bạn.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .contact-page {
        background: #f8f9fa;
        min-height: 100vh;
        padding-bottom: 2rem;
    }

    .contact-header {
        background: linear-gradient(135deg, #003d7a 0%, #005fa3 100%);
        color: white;
        padding: 3rem 1rem;
        text-align: center;
    }

    .header-content h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .header-content p {
        opacity: 0.9;
        font-size: 1.1rem;
    }

    /* Info Cards */
    .info-cards {
        max-width: 1200px;
        margin: -2rem auto 2rem;
        padding: 0 1rem;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        position: relative;
        z-index: 10;
    }

    .info-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        box-shadow: 0 4px 16px rgba(0, 61, 122, 0.1);
        transition: all 0.3s ease;
    }

    .info-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 61, 122, 0.15);
    }

    .info-icon {
        font-size: 2.5rem;
        margin-bottom: 0.8rem;
    }

    .info-card h3 {
        color: #003d7a;
        font-size: 1rem;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-weight: 700;
        color: #333;
        font-size: 1rem;
        margin: 0.3rem 0;
    }

    .info-desc {
        font-size: 0.85rem;
        color: #888;
    }

    /* Contact Content */
    .contact-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .contact-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-top: 2rem;
    }

    /* Form */
    .contact-form-card, .faq-card {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 61, 122, 0.1);
    }

    .contact-form-card h2, .faq-card h2 {
        color: #003d7a;
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
    }

    .form-desc {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }

    .form-group {
        margin-bottom: 1.2rem;
    }

    .form-group label {
        display: block;
        color: #333;
        font-weight: 600;
        margin-bottom: 0.4rem;
        font-size: 0.9rem;
    }

    .form-input {
        width: 100%;
        padding: 0.8rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    .form-input:focus {
        outline: none;
        border-color: #003d7a;
        background: #f0f5ff;
        box-shadow: 0 0 8px rgba(0, 61, 122, 0.2);
    }

    .textarea {
        resize: vertical;
        min-height: 100px;
    }

    .btn-submit {
        background: linear-gradient(135deg, #003d7a 0%, #0055aa 100%);
        color: white;
        border: none;
        padding: 0.9rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0, 61, 122, 0.3);
    }

    /* FAQ */
    .faq-item {
        border-bottom: 1px solid #f0f0f0;
        padding: 1.2rem 0;
    }

    .faq-item:last-child {
        border-bottom: none;
    }

    .faq-question {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        color: #003d7a;
        font-size: 0.95rem;
        margin-bottom: 0.6rem;
    }

    .faq-icon {
        font-size: 1.1rem;
    }

    .faq-answer {
        color: #555;
        font-size: 0.9rem;
        line-height: 1.7;
        padding-left: 1.7rem;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .info-cards {
            grid-template-columns: repeat(2, 1fr);
        }

        .contact-content {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .info-cards {
            grid-template-columns: 1fr;
        }

        .header-content h1 {
            font-size: 1.6rem;
        }
    }
</style>
